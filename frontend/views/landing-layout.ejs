<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <!-- ── Anti-FOUC : dark forcé AVANT tout rendu ── -->
  <script>document.documentElement.classList.add('dark');</script>
  <title><%= typeof pageTitle !== 'undefined' && pageTitle ? pageTitle + ' — StochastiQdata' : 'StochastiQdata — La plateforme data pour l\'assurance & la banque' %></title>

  <meta name="description" content="<%= typeof pageDescription !== 'undefined' && pageDescription ? pageDescription : 'Datasets qualifiés, modèles de référence et notebooks pour les professionnels de la data en assurance et banque.' %>">
  <meta name="robots" content="<%= typeof noIndex !== 'undefined' && noIndex ? 'noindex, nofollow' : 'index, follow' %>">
  <meta name="author" content="StochastiQdata">
  <link rel="canonical" href="<%= siteUrl %><%- typeof canonicalPath !== 'undefined' && canonicalPath ? canonicalPath : currentPath %>">

  <meta property="og:title" content="StochastiQdata — La plateforme data pour l'assurance & la banque">
  <meta property="og:description" content="<%= typeof pageDescription !== 'undefined' && pageDescription ? pageDescription : 'Datasets qualifiés, modèles et notebooks pour les pros de la data.' %>">
  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= siteUrl %>">
  <meta property="og:image" content="<%= siteUrl %>/images/og-cover.png">
  <meta property="og:site_name" content="StochastiQdata">
  <meta property="og:locale" content="fr_FR">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="StochastiQdata — La plateforme data pour l'assurance & la banque">
  <meta name="twitter:description" content="<%= typeof pageDescription !== 'undefined' && pageDescription ? pageDescription : 'Datasets qualifiés pour les pros de la data.' %>">
  <meta name="twitter:image" content="<%= siteUrl %>/images/og-cover.png">

  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/png" sizes="192x192" href="/images/logo.png">
  <link rel="shortcut icon" href="/favicon.svg">
  <link rel="apple-touch-icon" href="/images/logo.png">

  <link rel="preload" href="/css/output.css" as="style">
  <link rel="stylesheet" href="/css/output.css">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  <% if (typeof jsonLd !== 'undefined' && jsonLd) { %>
  <script type="application/ld+json"><%- JSON.stringify(jsonLd) %></script>
  <% } %>

  <style>
    /* Sidebar toujours en drawer (même sur desktop) dans le landing layout */
    #sidebar {
      transform: translateX(calc(-100% - 3rem)) !important;
      transition: transform 0.3s ease-in-out !important;
    }
    #sidebar.translate-x-0 {
      transform: translateX(0) !important;
    }
    /* ── Main content entrance ── */
    @keyframes landing-enter {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    main > div {
      animation: landing-enter 0.25s ease-out both;
    }
    /* Header slide-in */
    @keyframes nav-drop {
      from { opacity: 0; transform: translateY(-6px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    #landingHeader {
      animation: nav-drop 0.2s ease-out both;
    }
  </style>
</head>
<body class="bg-mesh min-h-screen transition-colors duration-300">

  <!-- Background decorations -->
  <div class="fixed inset-0 overflow-hidden pointer-events-none -z-10">
    <div class="absolute -top-40 -right-40 w-[600px] h-[600px] bg-gradient-to-br from-pink-500/20 to-purple-600/20 dark:from-pink-500/30 dark:to-purple-600/30 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-40 -left-40 w-[600px] h-[600px] bg-gradient-to-tr from-teal-400/20 to-cyan-500/20 dark:from-teal-400/30 dark:to-cyan-500/30 rounded-full blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] bg-gradient-to-r from-indigo-500/10 to-purple-500/10 dark:from-indigo-500/20 dark:to-purple-500/20 rounded-full blur-3xl"></div>
  </div>

  <!-- Sidebar (drawer — toujours caché, s'ouvre au clic hamburger) -->
  <%- include('partials/sidebar') %>

  <!-- Overlay sidebar -->
  <div id="sidebarOverlay" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[80] hidden"></div>

  <!-- ════════════════════════════════════════
       HEADER
  ════════════════════════════════════════ -->
  <div id="landingHeader" class="fixed top-0 left-0 right-0 z-[70] px-3 sm:px-4 lg:px-6 pt-3 lg:pt-4">
    <header class="glass rounded-xl lg:rounded-2xl px-3 sm:px-4 lg:px-6 py-3 lg:py-4 flex items-center gap-3 max-w-7xl mx-auto">

      <!-- Hamburger (mobile) -->
      <button id="hamburgerBtn"
              class="lg:hidden w-9 h-9 flex items-center justify-center text-gray-600 dark:text-gray-300"
              aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path d="M3 12h18"/><path d="M3 6h18"/><path d="M3 18h18"/>
        </svg>
      </button>

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 flex-shrink-0">
        <div class="w-8 h-8 rounded-lg overflow-hidden">
          <img src="/images/logo.png" alt="StochastiQdata" class="w-full h-full object-cover">
        </div>
        <span class="text-xl font-bold text-gray-900 dark:text-white">StochastiQdata</span>
      </a>

      <!-- Nav links — desktop uniquement -->
      <nav class="hidden lg:flex items-center gap-1 ml-4">
        <a href="/datasets"     class="px-3 py-2 rounded-xl text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-navy-700 transition-colors">Datasets</a>
        <a href="/modelisation" class="px-3 py-2 rounded-xl text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-navy-700 transition-colors">Modèles</a>
        <a href="/code"         class="px-3 py-2 rounded-xl text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-navy-700 transition-colors">Code</a>
        <a href="/communaute"   class="px-3 py-2 rounded-xl text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-navy-700 transition-colors">Communauté</a>
        <a href="/docs"         class="px-3 py-2 rounded-xl text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-navy-700 transition-colors">Docs</a>
      </nav>

      <!-- Spacer -->
      <div class="flex-1"></div>

      <!-- Actions droite -->
      <div class="flex items-center gap-2 sm:gap-3 flex-shrink-0">

        <!-- Date (desktop) -->
        <div class="hidden xl:flex flex-col items-end text-sm">
          <span id="currentDate" class="text-gray-600 dark:text-gray-300 font-medium"><%= currentDate %></span>
        </div>

<!-- Dark mode toggle -->
        <button id="themeToggle"
                class="w-9 h-9 lg:w-10 lg:h-10 rounded-xl bg-gray-100 dark:bg-navy-700 flex items-center justify-center text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 hover:bg-primary-50 dark:hover:bg-navy-600 transition-all"
                title="Toggle dark mode">
          <svg id="sunIcon" class="w-5 h-5 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/>
            <path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/>
            <path d="M2 12h2"/><path d="M20 12h2"/>
            <path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/>
          </svg>
          <svg id="moonIcon" class="w-5 h-5 block dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
          </svg>
        </button>
      </div>
    </header>
  </div>

  <!-- Page Content -->
  <main class="pt-[72px] lg:pt-24 pb-8 px-4 lg:px-6">
    <div class="max-w-7xl mx-auto">
      <%- body %>
    </div>
  </main>

  <script src="/js/main.js"></script>
  </script>
</body>
</html>
