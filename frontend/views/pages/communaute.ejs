<div class="max-w-5xl mx-auto">
  <!-- En-tête -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">Communauté</h1>
    <p class="text-gray-500 dark:text-gray-400">Articles, recherches, défis et ressources partagés par la communauté</p>
  </div>

  <!-- Catégories -->
  <div class="flex flex-wrap gap-2 mb-10">
    <button class="community-filter-btn px-4 py-1.5 text-sm font-medium rounded-full border border-primary-500 bg-primary-500/10 text-primary-600 dark:text-primary-400" data-filter="all">
      Tout
    </button>
    <button class="community-filter-btn px-4 py-1.5 text-sm font-medium rounded-full border border-gray-200 dark:border-navy-600 text-gray-600 dark:text-gray-300 hover:border-primary-500 hover:text-primary-500 transition-colors" data-filter="article">
      Articles
    </button>
    <button class="community-filter-btn px-4 py-1.5 text-sm font-medium rounded-full border border-gray-200 dark:border-navy-600 text-gray-600 dark:text-gray-300 hover:border-primary-500 hover:text-primary-500 transition-colors" data-filter="recherche">
      Recherches
    </button>
    <button class="community-filter-btn px-4 py-1.5 text-sm font-medium rounded-full border border-gray-200 dark:border-navy-600 text-gray-600 dark:text-gray-300 hover:border-primary-500 hover:text-primary-500 transition-colors" data-filter="defi">
      Défis
    </button>
    <button class="community-filter-btn px-4 py-1.5 text-sm font-medium rounded-full border border-gray-200 dark:border-navy-600 text-gray-600 dark:text-gray-300 hover:border-primary-500 hover:text-primary-500 transition-colors" data-filter="ressource">
      Ressources
    </button>
  </div>

  <!-- État vide — contenu à venir -->
  <div class="card py-20 px-16 text-center">
    <div class="inline-flex items-center justify-center w-20 h-20 rounded-3xl bg-primary-500/10 mb-10">
      <svg class="w-10 h-10 text-primary-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
        <circle cx="9" cy="7" r="4"/>
        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
      </svg>
    </div>
    <h2 class="text-2xl font-semibold text-gray-900 dark:text-white mb-6">La communauté se construit</h2>
    <p class="text-gray-500 dark:text-gray-400 max-w-lg mx-auto mb-12 leading-relaxed text-base">
      Articles, recherches, notebooks et défis publiés par les membres de la communauté et l'équipe StochastiQdata arriveront bientôt ici.
    </p>
    <div class="flex flex-wrap gap-8 justify-center text-sm text-gray-500 dark:text-gray-400">
      <span class="flex items-center gap-2">
        <svg class="w-5 h-5 text-primary-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
        Articles & Tutoriels
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-5 h-5 text-cyan-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
        Recherches & Publications
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-5 h-5 text-violet-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        Défis & Compétitions
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-5 h-5 text-amber-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
        Ressources & Notebooks
      </span>
    </div>
  </div>

  <!-- Rejoindre -->
  <div class="mt-8 card p-8 flex flex-col sm:flex-row items-center gap-6">
    <div class="flex-1">
      <h3 class="font-semibold text-gray-900 dark:text-white mb-1">Vous voulez contribuer ?</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400">
        Partagez vos analyses, notebooks ou découvertes avec la communauté.
        Contactez-nous à <span class="text-primary-500 font-medium">communaute@stochastiqdata.com</span>
      </p>
    </div>
    <a href="/add-dataset" class="flex-shrink-0 px-5 py-2.5 bg-gradient-to-r from-primary-500 to-teal-500 hover:from-primary-600 hover:to-teal-600 text-white font-semibold rounded-xl transition-all text-sm shadow hover:shadow-lg">
      Contribuer
    </a>
  </div>
</div>

<script>
  document.querySelectorAll('.community-filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.community-filter-btn').forEach(b => {
        b.classList.remove('border-primary-500', 'bg-primary-500/10', 'text-primary-600', 'dark:text-primary-400');
        b.classList.add('border-gray-200', 'dark:border-navy-600', 'text-gray-600', 'dark:text-gray-300');
      });
      btn.classList.remove('border-gray-200', 'dark:border-navy-600', 'text-gray-600', 'dark:text-gray-300');
      btn.classList.add('border-primary-500', 'bg-primary-500/10', 'text-primary-600', 'dark:text-primary-400');
    });
  });
</script>
