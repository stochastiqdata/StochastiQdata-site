<script>
// Filtres
document.getElementById('code-filters').addEventListener('click', function(e) {
  const btn = e.target.closest('button[data-filter]');
  if (!btn) return;
  this.querySelectorAll('button').forEach(b => {
    b.className = 'inactive-pill filter-pill';
  });
  btn.className = 'active-pill filter-pill';
  const filter = btn.dataset.filter;
  document.querySelectorAll('.code-card').forEach(card => {
    const tags = (card.dataset.tags || '') + ' ' + (card.closest('.code-section')?.dataset.section || '');
    card.closest('div').style.display = (filter === 'all' || tags.includes(filter)) ? '' : 'none';
  });
  // Masquer les sections vides
  document.querySelectorAll('.code-section').forEach(sec => {
    const visible = [...sec.querySelectorAll('.code-card')].some(c => c.closest('div').style.display !== 'none');
    sec.style.display = visible ? '' : 'none';
  });
});

// Recherche
document.getElementById('code-search').addEventListener('input', function() {
  const q = this.value.toLowerCase().trim();
  document.querySelectorAll('.code-card').forEach(card => {
    const text = card.textContent.toLowerCase();
    card.closest('div').style.display = (!q || text.includes(q)) ? '' : 'none';
  });
});
</script>

<style>
.filter-pill {
  display: inline-flex;
  align-items: center;
  padding: 0.375rem 1rem;
  font-size: 0.875rem;
  font-weight: 500;
  border-radius: 9999px;
  border: 1px solid;
  cursor: pointer;
  transition: all 0.15s;
}
.inactive-pill {
  border-color: #e5e7eb;
  color: #6b7280;
  background: transparent;
}
.dark .inactive-pill {
  border-color: #334155;
  color: #9ca3af;
}
.inactive-pill:hover {
  border-color: #3b82f6;
  color: #3b82f6;
}
.active-pill {
  border-color: #3b82f6;
  background: rgba(59,130,246,0.12);
  color: #3b82f6;
}
</style>
