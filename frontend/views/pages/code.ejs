<div class="max-w-6xl mx-auto">

  <!-- En-tête -->
  <div class="mb-6">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-1">Code</h1>
    <p class="text-gray-500 dark:text-gray-400">Notebooks et scripts prêts à l'emploi — assurance, banque, fraude, pricing</p>
  </div>

  <!-- Barre de recherche pleine largeur -->
  <div class="relative mb-6">
    <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 pointer-events-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
    <input id="code-search" type="text" placeholder="Rechercher par titre, algorithme ou dataset…"
      class="w-full pl-12 pr-5 py-3 text-sm bg-navy-800 border border-navy-600 rounded-2xl text-white placeholder-gray-500 focus:outline-none focus:border-primary-500/60 focus:ring-2 focus:ring-primary-500/20 transition-all">
    <kbd class="absolute right-4 top-1/2 -translate-y-1/2 text-[10px] text-gray-500 bg-navy-700 border border-navy-600 rounded px-1.5 py-0.5 hidden sm:block">⌘K</kbd>
  </div>

  <!-- Filtres -->
  <div class="flex flex-wrap gap-2 mb-8" id="code-filters">
    <% [
      {key:'all',   label:'Tout'},
      {key:'assurance', label:'Assurance'},
      {key:'banque',    label:'Banque'},
      {key:'fraude',    label:'Fraude'},
      {key:'pricing',   label:'Pricing'},
      {key:'risque',    label:'Risque de crédit'},
      {key:'sante',     label:'Santé'},
      {key:'ml',        label:'Machine Learning'},
    ].forEach((f, i) => { %>
      <button class="filter-pill <%= i===0 ? 'active-pill' : 'inactive-pill' %>" data-filter="<%= f.key %>"><%= f.label %></button>
    <% }); %>
