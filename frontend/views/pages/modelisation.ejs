<div class="max-w-5xl mx-auto px-4 py-8">

  <!-- Header -->
  <div class="flex items-center justify-between gap-4 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Modèles actuariels</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">
        <span id="statTotal" class="font-medium text-gray-700 dark:text-gray-300">—</span> modèles ·
        <span id="statDatasets" class="font-medium text-gray-700 dark:text-gray-300">—</span> datasets
      </p>
    </div>
    <a href="/"
       class="shrink-0 inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-violet-500 hover:bg-violet-600 text-white font-semibold text-sm transition-all shadow">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Soumettre
    </a>
  </div>

  <!-- Filtres par type -->
  <div class="flex flex-wrap gap-2 mb-6">
    <button onclick="filterModels('all')" data-filter="all"
      class="filter-btn active px-3 py-1.5 text-sm rounded-lg border font-medium transition-colors
             border-violet-500 bg-violet-50 dark:bg-violet-900/20 text-violet-700 dark:text-violet-300">
      Tous
    </button>
    <% [['glm','GLM'],['xgboost','XGBoost'],['lightgbm','LightGBM'],['catboost','CatBoost'],
        ['neural_network','Neural Network'],['other','Autre']].forEach(([val,label]) => { %>
    <button onclick="filterModels('<%= val %>')" data-filter="<%= val %>"
      class="filter-btn px-3 py-1.5 text-sm rounded-lg border font-medium transition-colors
             border-gray-200 dark:border-navy-600 text-gray-600 dark:text-gray-400 hover:border-violet-400 dark:hover:border-violet-500">
      <%= label %>
    </button>
    <% }); %>
  </div>

  <!-- Loading -->
  <div id="communityLoading" class="flex items-center gap-2 text-sm text-gray-400 dark:text-gray-500 mb-6">
    <svg class="w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
    </svg>
    Chargement des modèles…
  </div>

  <!-- Sections modèles par niveau -->
  <div id="communityGrid" class="hidden mb-10"></div>

  <!-- Empty state -->
  <div id="communityEmpty" class="hidden text-center py-16 mb-10">
    <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-violet-50 dark:bg-violet-900/20 flex items-center justify-center">
      <svg class="w-8 h-8 text-violet-300 dark:text-violet-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/>
        <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
        <line x1="12" y1="19" x2="12" y2="22"/>
      </svg>
    </div>
    <p class="text-gray-500 dark:text-gray-400 mb-1">Aucun modèle soumis pour ce filtre.</p>
    <p class="text-sm text-gray-400 dark:text-gray-500">Ouvrez un dataset et soumettez le vôtre.</p>
    <a href="/" class="mt-4 inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-lg border border-violet-400 text-violet-600 dark:text-violet-400 hover:bg-violet-50 dark:hover:bg-violet-900/20 transition-colors">
      Parcourir les datasets →
    </a>
  </div>


</div>

<script>
(function () {
  const TYPE_ICONS = {
    glm: '📐', xgboost: '⚡', random_forest: '🌲', neural_network: '🧠',
    lightgbm: '💡', catboost: '🐱', chain_ladder: '📊', cox: '📈',
    kaplan_meier: '📉', bornhuetter_ferguson: '📋', other: '🔬'
  };
  const TYPE_LABELS = {
    glm: 'GLM', xgboost: 'XGBoost', random_forest: 'Random Forest',
    neural_network: 'Réseau de neurones', lightgbm: 'LightGBM', catboost: 'CatBoost',
    chain_ladder: 'Chain Ladder', bornhuetter_ferguson: 'Bornhuetter-Ferguson',
    cox: 'Cox', kaplan_meier: 'Kaplan-Meier', other: 'Autre'
  };
  const METRIC_LABELS = {
    gini: 'Gini', rmse: 'RMSE', mae: 'MAE', aic: 'AIC', bic: 'BIC',
    r2: 'R²', log_loss: 'Log Loss', auc: 'AUC', accuracy: 'Accuracy', f1_score: 'F1'
  };

  let allModels = [];
  let currentFilter = 'all';

  const DIFF_SECTIONS = [
    { key: 'niveau-1', label: 'Débutant',      color: 'text-emerald-600 dark:text-emerald-400', border: 'border-emerald-200 dark:border-emerald-800' },
    { key: 'niveau-2', label: 'Intermédiaire', color: 'text-amber-600 dark:text-amber-400',     border: 'border-amber-200 dark:border-amber-800' },
    { key: 'niveau-3', label: 'Avancé',        color: 'text-rose-600 dark:text-rose-400',       border: 'border-rose-200 dark:border-rose-800' },
  ];

  const DIFF_BADGE = {
    'niveau-1': 'bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400',
    'niveau-2': 'bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400',
    'niveau-3': 'bg-rose-100 dark:bg-rose-900/30 text-rose-700 dark:text-rose-400',
  };

  function getDifficulty(model) {
    const tags = model.tags || [];
    for (const k of ['niveau-1','niveau-2','niveau-3']) {
      if (tags.includes(k)) return k;
    }
    return null;
  }

  function formatMetricValue(k, v) {
    if (typeof v === 'number') {
      return ['gini', 'r2', 'auc', 'accuracy', 'f1_score'].includes(k)
        ? (v * 100).toFixed(1) + '%' : v.toFixed(4);
    }
    return String(v);
  }

  function renderCard(model) {
    const icon = TYPE_ICONS[model.model_type] || '🔬';
    const typeLabel = TYPE_LABELS[model.model_type] || model.model_type;
    const desc = (model.description || '').replace(/^(Débutant|Intermédiaire|Avancé)\s*·\s*/i, '');

    const metrics = Object.entries(model.metrics || {}).slice(0, 2);
    const familyBadge = model.family
      ? `<span class="px-2 py-0.5 text-xs rounded-full bg-violet-100 dark:bg-violet-900/30 text-violet-700 dark:text-violet-300">${model.family}</span>`
      : '';
    const fileBadge = model.model_file_url
      ? `<span class="px-2 py-0.5 text-xs rounded-full bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400">↓ fichier</span>`
      : '';

    return `
      <a href="/models/${model.id}"
         class="block card p-4 hover:border-violet-400 dark:hover:border-violet-600 hover:shadow-md transition-all group border border-transparent">
        <div class="flex items-start gap-3 mb-2">
          <span class="text-xl shrink-0 mt-0.5">${icon}</span>
          <div class="min-w-0 flex-1">
            <p class="font-semibold text-gray-900 dark:text-white group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors truncate">${model.name}</p>
            <p class="text-xs text-gray-400 dark:text-gray-500 mt-0.5">${typeLabel}</p>
          </div>
          <svg class="w-4 h-4 text-gray-300 dark:text-gray-600 group-hover:text-violet-400 shrink-0 mt-1 transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        </div>
        ${desc ? `<p class="text-xs text-gray-500 dark:text-gray-400 line-clamp-2 mb-3">${desc}</p>` : ''}
        <div class="flex items-center justify-between gap-2">
          <div class="flex flex-wrap gap-1.5">${familyBadge}${fileBadge}
            ${metrics.map(([k,v]) =>
              `<span class="px-2 py-0.5 text-xs rounded-full bg-gray-100 dark:bg-navy-700 text-gray-600 dark:text-gray-300">
                ${METRIC_LABELS[k]||k}: <strong>${formatMetricValue(k,v)}</strong>
              </span>`
            ).join('')}
          </div>
          ${model.notebook_url
            ? `<a href="${model.notebook_url}" target="_blank" rel="noopener" onclick="event.stopPropagation()"
                 class="shrink-0 text-xs text-violet-500 hover:text-violet-600 dark:hover:text-violet-300 font-medium whitespace-nowrap">
                 Source →
               </a>`
            : ''}
        </div>
      </a>
    `;
  }

  function renderGrid(models) {
    const grid = document.getElementById('communityGrid');
    const empty = document.getElementById('communityEmpty');

    if (!models.length) {
      grid.classList.add('hidden');
      empty.classList.remove('hidden');
      return;
    }

    empty.classList.add('hidden');

    // Groupe par niveau
    let html = '';
    for (const section of DIFF_SECTIONS) {
      const group = models.filter(m => (m.tags || []).includes(section.key));
      if (!group.length) continue;
      html += `
        <div class="mb-8">
          <div class="flex items-center gap-3 mb-4">
            <h3 class="text-sm font-bold uppercase tracking-widest ${section.color}">${section.label}</h3>
            <span class="text-xs text-gray-400">${group.length} modèle${group.length > 1 ? 's' : ''}</span>
            <div class="flex-1 h-px border-t ${section.border}"></div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            ${group.map(renderCard).join('')}
          </div>
        </div>
      `;
    }
    // Modèles sans niveau défini
    const ungrouped = models.filter(m => !getDifficulty(m));
    if (ungrouped.length) {
      html += `<div class="grid grid-cols-1 md:grid-cols-2 gap-4">${ungrouped.map(renderCard).join('')}</div>`;
    }

    grid.innerHTML = html;
    grid.classList.remove('hidden');
  }

  function applyFilters() {
    let filtered = allModels;
    if (currentFilter !== 'all') filtered = filtered.filter(m => m.model_type === currentFilter);
    renderGrid(filtered);
  }

  window.filterModels = function(filter) {
    currentFilter = filter;
    document.querySelectorAll('.filter-btn').forEach(btn => {
      const active = btn.dataset.filter === filter;
      btn.classList.toggle('border-violet-500', active);
      btn.classList.toggle('bg-violet-50', active);
      btn.classList.toggle('dark:bg-violet-900/20', active);
      btn.classList.toggle('text-violet-700', active);
      btn.classList.toggle('dark:text-violet-300', active);
      btn.classList.toggle('border-gray-200', !active);
      btn.classList.toggle('dark:border-navy-600', !active);
      btn.classList.toggle('text-gray-600', !active);
      btn.classList.toggle('dark:text-gray-400', !active);
    });
    applyFilters();
  };

  fetch('/api/models')
    .then(r => r.json())
    .then(models => {
      document.getElementById('communityLoading').classList.add('hidden');
      allModels = models;

      // Stats inline
      document.getElementById('statTotal').textContent = models.length;
      document.getElementById('statDatasets').textContent = new Set(models.map(m => m.dataset_id)).size;

      renderGrid(models);
    })
    .catch(() => {
      document.getElementById('communityLoading').classList.add('hidden');
      document.getElementById('communityEmpty').classList.remove('hidden');
    });
})();
</script>
