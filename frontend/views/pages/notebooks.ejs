<div class="max-w-5xl mx-auto px-4 py-8">

  <!-- En-tête -->
  <div class="mb-8 flex items-start justify-between flex-wrap gap-4">
    <div>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">Notebooks</h1>
      <p class="text-gray-500 dark:text-gray-400 text-sm">Analyses Jupyter & Colab partagées par la communauté actuarielle. Exécutez directement dans votre navigateur.</p>
    </div>
    <a href="https://colab.research.google.com/#create=true" target="_blank" rel="noopener noreferrer"
       class="inline-flex items-center gap-2 px-4 py-2.5 bg-amber-500 hover:bg-amber-600 text-white font-semibold text-sm rounded-xl transition-all shadow-md hover:scale-[1.02]">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 5v14"/><path d="M5 12h14"/>
      </svg>
      Nouveau notebook Colab
    </a>
  </div>

  <!-- Templates par catégorie -->
  <div class="mb-10">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Templates de démarrage</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">

      <!-- GLM Poisson -->
      <div class="card p-5 hover:border-amber-400 dark:hover:border-amber-500 border border-transparent transition-colors">
        <div class="flex items-start justify-between mb-3">
          <div class="w-9 h-9 rounded-lg bg-amber-100 dark:bg-amber-900/30 flex items-center justify-center">
            <svg class="w-4 h-4 text-amber-600 dark:text-amber-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
              <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
            </svg>
          </div>
          <span class="text-xs px-2 py-0.5 rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300 font-medium">Colab</span>
        </div>
        <h3 class="font-semibold text-gray-900 dark:text-white mb-1 text-sm">GLM Poisson — freMTPL2</h3>
        <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">Modèle de fréquence sinistres auto. Chargement OpenML + GLM Poisson + métriques.</p>
        <div class="flex items-center justify-between">
          <div class="flex gap-1.5">
            <span class="tag tag-iard text-xs">IARD</span>
            <span class="tag tag-glm text-xs">GLM</span>
          </div>
          <a href="https://colab.research.google.com/#create=true" target="_blank" rel="noopener noreferrer"
             class="text-xs font-semibold text-amber-500 hover:text-amber-600 flex items-center gap-1">
            Ouvrir <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        </div>
      </div>

      <!-- Chain Ladder -->
      <div class="card p-5 hover:border-teal-400 dark:hover:border-teal-500 border border-transparent transition-colors">
        <div class="flex items-start justify-between mb-3">
          <div class="w-9 h-9 rounded-lg bg-teal-100 dark:bg-teal-900/30 flex items-center justify-center">
            <svg class="w-4 h-4 text-teal-600 dark:text-teal-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 22 22 2 22"/></svg>
          </div>
          <span class="text-xs px-2 py-0.5 rounded-full bg-teal-100 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300 font-medium">Colab</span>
        </div>
        <h3 class="font-semibold text-gray-900 dark:text-white mb-1 text-sm">Chain Ladder — Provisionnement</h3>
        <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">Triangles de développement IBNR avec chainladder Python.</p>
        <div class="flex items-center justify-between">
          <span class="tag tag-reserving text-xs">Reserving</span>
          <a href="https://colab.research.google.com/#create=true" target="_blank" rel="noopener noreferrer"
             class="text-xs font-semibold text-teal-500 hover:text-teal-600 flex items-center gap-1">
            Ouvrir <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        </div>
      </div>

      <!-- Kaplan-Meier -->
      <div class="card p-5 hover:border-pink-400 dark:hover:border-pink-500 border border-transparent transition-colors">
        <div class="flex items-start justify-between mb-3">
          <div class="w-9 h-9 rounded-lg bg-pink-100 dark:bg-pink-900/30 flex items-center justify-center">
            <svg class="w-4 h-4 text-pink-600 dark:text-pink-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <span class="text-xs px-2 py-0.5 rounded-full bg-pink-100 dark:bg-pink-900/30 text-pink-700 dark:text-pink-300 font-medium">Colab</span>
        </div>
        <h3 class="font-semibold text-gray-900 dark:text-white mb-1 text-sm">Kaplan-Meier — Mortalité</h3>
        <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">Analyse de survie sur tables de mortalité HMD. Courbes S(t) + test log-rank.</p>
        <div class="flex items-center justify-between">
          <span class="tag tag-vie text-xs">Vie</span>
          <a href="https://colab.research.google.com/#create=true" target="_blank" rel="noopener noreferrer"
             class="text-xs font-semibold text-pink-500 hover:text-pink-600 flex items-center gap-1">
            Ouvrir <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        </div>
      </div>

      <!-- XGBoost Fraude -->
      <div class="card p-5 hover:border-red-400 dark:hover:border-red-500 border border-transparent transition-colors">
        <div class="flex items-start justify-between mb-3">
          <div class="w-9 h-9 rounded-lg bg-red-100 dark:bg-red-900/30 flex items-center justify-center">
            <svg class="w-4 h-4 text-red-600 dark:text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          </div>
          <span class="text-xs px-2 py-0.5 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 font-medium">Kaggle</span>
        </div>
        <h3 class="font-semibold text-gray-900 dark:text-white mb-1 text-sm">XGBoost — Détection de fraude</h3>
        <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">SMOTE + XGBoost + SHAP sur Vehicle Claim Fraud dataset.</p>
        <div class="flex items-center justify-between">
          <span class="tag tag-fraude text-xs">Fraude</span>
          <a href="https://www.kaggle.com" target="_blank" rel="noopener noreferrer"
             class="text-xs font-semibold text-blue-500 hover:text-blue-600 flex items-center gap-1">
            Ouvrir <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        </div>
      </div>

      <!-- Tweedie -->
      <div class="card p-5 hover:border-violet-400 dark:hover:border-violet-500 border border-transparent transition-colors">
        <div class="flex items-start justify-between mb-3">
          <div class="w-9 h-9 rounded-lg bg-violet-100 dark:bg-violet-900/30 flex items-center justify-center">
            <svg class="w-4 h-4 text-violet-600 dark:text-violet-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
          </div>
          <span class="text-xs px-2 py-0.5 rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300 font-medium">Colab</span>
        </div>
        <h3 class="font-semibold text-gray-900 dark:text-white mb-1 text-sm">Tweedie — Prime pure</h3>
        <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">Modèle combiné fréquence×coût. TweedieRegressor sklearn + optimisation du paramètre p.</p>
        <div class="flex items-center justify-between">
          <div class="flex gap-1.5">
            <span class="tag tag-iard text-xs">IARD</span>
            <span class="tag tag-pricing text-xs">Pricing</span>
          </div>
          <a href="https://colab.research.google.com/#create=true" target="_blank" rel="noopener noreferrer"
             class="text-xs font-semibold text-violet-500 hover:text-violet-600 flex items-center gap-1">
            Ouvrir <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        </div>
      </div>

      <!-- EDA Santé -->
      <div class="card p-5 hover:border-green-400 dark:hover:border-green-500 border border-transparent transition-colors">
        <div class="flex items-start justify-between mb-3">
          <div class="w-9 h-9 rounded-lg bg-green-100 dark:bg-green-900/30 flex items-center justify-center">
            <svg class="w-4 h-4 text-green-600 dark:text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
          </div>
          <span class="text-xs px-2 py-0.5 rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300 font-medium">Colab</span>
        </div>
        <h3 class="font-semibold text-gray-900 dark:text-white mb-1 text-sm">EDA — Dépenses de santé</h3>
        <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">Analyse exploratoire MEPS. Courbe de Lorenz + distribution des coûts + GLM Gamma.</p>
        <div class="flex items-center justify-between">
          <span class="tag tag-sante text-xs">Santé</span>
          <a href="https://colab.research.google.com/#create=true" target="_blank" rel="noopener noreferrer"
             class="text-xs font-semibold text-green-500 hover:text-green-600 flex items-center gap-1">
            Ouvrir <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        </div>
      </div>

    </div>
  </div>

  <!-- Notebooks communauté -->
  <div>
    <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Notebooks de la communauté</h2>
    <% if (notebooks && notebooks.length > 0) { %>
      <div class="space-y-3">
        <% notebooks.forEach(function(nb) { %>
          <a href="<%= nb.url %>" target="_blank" rel="noopener noreferrer"
             class="flex items-center gap-4 p-4 card hover:border-cyan-400 dark:hover:border-cyan-600 border border-transparent transition-all group">
            <div class="w-10 h-10 rounded-xl <%= nb.platform === 'kaggle' ? 'bg-blue-100 dark:bg-blue-900/30' : 'bg-amber-100 dark:bg-amber-900/30' %> flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 <%= nb.platform === 'kaggle' ? 'text-blue-600 dark:text-blue-400' : 'text-amber-600 dark:text-amber-400' %>" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="font-medium text-gray-900 dark:text-white group-hover:text-cyan-700 dark:group-hover:text-cyan-300 truncate"><%= nb.title %></p>
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5 capitalize"><%= nb.platform %> · <%= nb.author %></p>
            </div>
            <span class="text-xs px-2 py-0.5 rounded-full <%= nb.platform === 'kaggle' ? 'bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400' : 'bg-amber-100 dark:bg-amber-900/30 text-amber-600 dark:text-amber-400' %> font-medium capitalize shrink-0"><%= nb.platform %></span>
          </a>
        <% }); %>
      </div>
    <% } else { %>
      <div class="flex flex-col items-center justify-center py-16 text-center rounded-2xl border border-dashed border-gray-200 dark:border-navy-700">
        <svg class="w-12 h-12 text-gray-200 dark:text-navy-700 mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
          <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
        </svg>
        <p class="text-gray-500 dark:text-gray-400 font-medium mb-1">Aucun notebook partagé pour l'instant</p>
        <p class="text-gray-400 dark:text-gray-600 text-sm">Partagez le vôtre depuis la page d'un dataset !</p>
      </div>
    <% } %>
  </div>

</div>
