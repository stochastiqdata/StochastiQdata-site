<script>
(function () {
  var BASE = 338;

  // ── Compteurs ──────────────────────────────────────────────
  function runCounters() {
    document.querySelectorAll('.counter').forEach(function (el) {
      var target = parseInt(el.dataset.target, 10);
      var start  = null;
      (function step(ts) {
        if (!start) start = ts;
        var p = Math.min((ts - start) / 1800, 1);
        el.textContent = Math.floor((1 - Math.pow(1 - p, 3)) * target);
        if (p < 1) requestAnimationFrame(step); else el.textContent = target;
      })(performance.now());
    });
  }

  // ── Barres : croissance ────────────────────────────────────
  var bars = [
    {id:'b1',h:66},{id:'b2',h:96},{id:'b3',h:50},
    {id:'b4',h:80},{id:'b5',h:110},{id:'b6',h:74},{id:'b7',h:88}
  ];

  function growBars() {
    bars.forEach(function (bar, i) {
      setTimeout(function () {
        var el = document.getElementById(bar.id); if (!el) return;
        var s = null;
        (function tick(ts) {
          if (!s) s = ts;
          var p = Math.min((ts - s) / 680, 1);
          var h = Math.round((1 - Math.pow(1 - p, 3)) * bar.h);
          el.setAttribute('y', BASE - h);
          el.setAttribute('height', h);
          if (p < 1) requestAnimationFrame(tick);
        })(performance.now());
      }, 900 + i * 85);
    });
  }

  // ── Barres : respiration ───────────────────────────────────
  function breatheBars() {
    bars.forEach(function (bar, i) {
      var el = document.getElementById(bar.id); if (!el) return;
      var amp   = bar.h * 0.07;
      var speed = 2600 + i * 270;
      var phase = i * (Math.PI / bars.length);
      (function tick() {
        var h = Math.round(bar.h + amp * Math.sin(Date.now() / speed * 2 * Math.PI + phase));
        el.setAttribute('y', BASE - h);
        el.setAttribute('height', h);
        requestAnimationFrame(tick);
      })();
    });
  }

  document.addEventListener('DOMContentLoaded', function () {
    runCounters();
    growBars();
    setTimeout(breatheBars, 2700);
  });
})();
</script>
