  .float-a { animation: float-a 4.2s ease-in-out infinite; }
  .float-b { animation: float-b 5.0s ease-in-out infinite 0.8s; }
  .float-c { animation: float-c 3.8s ease-in-out infinite 1.6s; }

  /* ── Typing cursor ── */
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
  .cursor { animation: blink 1s step-end infinite; }

  /* ── Domain tags hover ── */
  .domain-tag { transition: transform 0.25s ease, box-shadow 0.25s ease, background-color 0.25s ease, border-color 0.25s ease; }
