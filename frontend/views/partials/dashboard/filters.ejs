<!-- Filtres dans une card glass -->
<div class="glass rounded-2xl p-3 sm:p-5 mb-6 relative z-[50] max-w-full overflow-hidden">
  <form action="/" method="GET" class="space-y-4">

    <!-- Row 1: Tri + Actions -->
    <div class="flex flex-wrap items-center gap-3">
      <!-- Tri - Custom Dropdown -->
      <div class="relative" id="sortDropdown">
        <input type="hidden" name="sortBy" id="sortByInput" value="<%= filters.sortBy || 'created_at' %>">
        <button type="button" id="sortDropdownBtn" class="flex items-center gap-2 px-4 py-2.5 rounded-xl border border-gray-200 dark:border-navy-600 bg-white dark:bg-navy-700 text-gray-900 dark:text-white text-sm hover:border-primary-400 dark:hover:border-primary-500 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all min-w-[160px] shadow-sm">
          <svg class="w-4 h-4 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="m3 16 4 4 4-4"/>
            <path d="M7 20V4"/>
            <path d="m21 8-4-4-4 4"/>
            <path d="M17 4v16"/>
          </svg>
          <span id="sortDropdownLabel" class="flex-1 text-left font-medium">
            <%
              const sortLabels = {
                'created_at': "Récents",
                'global_score': 'Meilleurs scores',
                'review_count': "Plus d'avis",
                'name': 'A → Z'
              };
            %>
            <%= sortLabels[filters.sortBy] || 'Récents' %>
          </span>
          <svg class="w-4 h-4 text-gray-400 transition-transform duration-200" id="sortDropdownArrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="m6 9 6 6 6-6"/>
          </svg>
        </button>

        <!-- Dropdown Menu -->
        <div id="sortDropdownMenu" class="absolute top-full left-0 mt-2 py-2 rounded-xl border border-gray-200 dark:border-navy-600 bg-white dark:bg-navy-800 shadow-2xl z-[100] hidden opacity-0 transform -translate-y-2 transition-all duration-200 min-w-[220px]">
          <div class="px-3 py-2 border-b border-gray-100 dark:border-navy-700 mb-1">
            <span class="text-xs font-semibold text-gray-400 dark:text-gray-500 uppercase tracking-wider">Trier par</span>
          </div>
          <button type="button" class="sort-option w-full flex items-center gap-3 px-4 py-2.5 text-sm text-left hover:bg-primary-50 dark:hover:bg-navy-700 transition-colors <%= filters.sortBy === 'created_at' || !filters.sortBy ? 'text-primary-600 dark:text-primary-400 bg-primary-50/50 dark:bg-primary-500/10' : 'text-gray-700 dark:text-gray-300' %>" data-value="created_at">
            <div class="w-8 h-8 rounded-lg bg-white dark:bg-navy-700 border border-gray-200 dark:border-navy-600 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-cyan-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 8v4l3 3"/>
                <circle cx="12" cy="12" r="10"/>
              </svg>
            </div>
            <div class="flex-1">
              <span class="font-medium">Récents</span>
              <p class="text-xs text-gray-400 dark:text-gray-500">Les derniers ajoutés</p>
            </div>
            <% if (filters.sortBy === 'created_at' || !filters.sortBy) { %>
              <svg class="w-5 h-5 text-primary-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            <% } %>
          </button>
          <button type="button" class="sort-option w-full flex items-center gap-3 px-4 py-2.5 text-sm text-left hover:bg-primary-50 dark:hover:bg-navy-700 transition-colors <%= filters.sortBy === 'global_score' ? 'text-primary-600 dark:text-primary-400 bg-primary-50/50 dark:bg-primary-500/10' : 'text-gray-700 dark:text-gray-300' %>" data-value="global_score">
            <div class="w-8 h-8 rounded-lg bg-white dark:bg-navy-700 border border-gray-200 dark:border-navy-600 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-amber-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            </div>
            <div class="flex-1">
              <span class="font-medium">Meilleurs scores</span>
              <p class="text-xs text-gray-400 dark:text-gray-500">Les mieux notés</p>
            </div>
            <% if (filters.sortBy === 'global_score') { %>
              <svg class="w-5 h-5 text-primary-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            <% } %>
          </button>
          <button type="button" class="sort-option w-full flex items-center gap-3 px-4 py-2.5 text-sm text-left hover:bg-primary-50 dark:hover:bg-navy-700 transition-colors <%= filters.sortBy === 'review_count' ? 'text-primary-600 dark:text-primary-400 bg-primary-50/50 dark:bg-primary-500/10' : 'text-gray-700 dark:text-gray-300' %>" data-value="review_count">
            <div class="w-8 h-8 rounded-lg bg-white dark:bg-navy-700 border border-gray-200 dark:border-navy-600 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-purple-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
            <div class="flex-1">
              <span class="font-medium">Plus d'avis</span>
              <p class="text-xs text-gray-400 dark:text-gray-500">Les plus populaires</p>
            </div>
            <% if (filters.sortBy === 'review_count') { %>
              <svg class="w-5 h-5 text-primary-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            <% } %>
          </button>
          <button type="button" class="sort-option w-full flex items-center gap-3 px-4 py-2.5 text-sm text-left hover:bg-primary-50 dark:hover:bg-navy-700 transition-colors <%= filters.sortBy === 'name' ? 'text-primary-600 dark:text-primary-400 bg-primary-50/50 dark:bg-primary-500/10' : 'text-gray-700 dark:text-gray-300' %>" data-value="name">
            <div class="w-8 h-8 rounded-lg bg-white dark:bg-navy-700 border border-gray-200 dark:border-navy-600 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 7V4h16v3"/>
                <path d="M9 20h6"/>
                <path d="M12 4v16"/>
              </svg>
            </div>
            <div class="flex-1">
              <span class="font-medium">A → Z</span>
              <p class="text-xs text-gray-400 dark:text-gray-500">Ordre alphabétique</p>
            </div>
            <% if (filters.sortBy === 'name') { %>
              <svg class="w-5 h-5 text-primary-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            <% } %>
          </button>
        </div>
      </div>

      <!-- Boutons d'action -->
      <button type="submit" class="btn-primary">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        <span>Appliquer</span>
      </button>

      <a href="/" class="btn-ghost">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
          <path d="M3 3v5h5"/>
        </svg>
        Réinitialiser
      </a>

      <div class="flex-1"></div>

      <p class="text-sm text-gray-500 dark:text-gray-400">
        <strong class="text-gray-900 dark:text-white"><%= total %></strong> dataset<%= total !== 1 ? 's' : '' %>
      </p>
    </div>

    <!-- Séparateur -->
    <div class="border-t border-gray-200 dark:border-navy-700"></div>

    <!-- Row 2: Filtre Source -->
    <div class="flex flex-wrap items-center gap-2">
      <span class="text-sm font-medium text-gray-500 dark:text-gray-400 flex items-center gap-1.5 min-w-[80px]">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12a9 9 0 0 1-9 9m9-9a9 9 0 0 0-9-9m9 9H3m9 9a9 9 0 0 1-9-9m9 9c1.66 0 3-4.03 3-9s-1.34-9-3-9m0 18c-1.66 0-3-4.03-3-9s1.34-9 3-9m-9 9a9 9 0 0 1 9-9"/>
        </svg>
        Source
      </span>
      <div class="flex flex-wrap gap-2">
        <label class="inline-flex items-center cursor-pointer">
          <input type="radio" name="source" value="" <%= !filters.source ? 'checked' : '' %> class="sr-only peer">
          <span class="px-3 py-1.5 rounded-lg text-sm font-medium border border-gray-200 dark:border-navy-600 bg-white dark:bg-navy-700 text-gray-600 dark:text-gray-300 peer-checked:bg-primary-500 peer-checked:text-white peer-checked:border-primary-500 hover:border-primary-300 dark:hover:border-primary-500 transition-all">
            Toutes
          </span>
        </label>
        <% ['kaggle', 'opendata', 'insee', 'other'].forEach(source => { %>
          <label class="inline-flex items-center cursor-pointer">
            <input type="radio" name="source" value="<%= source %>" <%= filters.source === source ? 'checked' : '' %> class="sr-only peer">
            <span class="px-3 py-1.5 rounded-lg text-sm font-medium border border-gray-200 dark:border-navy-600 bg-white dark:bg-navy-700 text-gray-600 dark:text-gray-300 peer-checked:bg-primary-500 peer-checked:text-white peer-checked:border-primary-500 hover:border-primary-300 dark:hover:border-primary-500 transition-all">
              <%= SOURCE_LABELS[source] %>
            </span>
          </label>
        <% }); %>
      </div>
    </div>

    <!-- Row 3: Type de modélisation -->
    <div class="flex flex-wrap items-center gap-2">
      <span class="text-sm font-medium text-gray-500 dark:text-gray-400 flex items-center gap-1.5 min-w-[80px]">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 20V10"/>
          <path d="M18 20V4"/>
          <path d="M6 20v-4"/>
        </svg>
        Type
      </span>
      <div class="flex flex-wrap gap-2">
        <% ['classification', 'regression', 'time_series', 'clustering', 'survival'].forEach(type => { %>
          <label class="inline-flex items-center cursor-pointer">
            <input type="checkbox" name="modelingTypes" value="<%= type %>" <%= (filters.modelingTypes || '').includes(type) ? 'checked' : '' %> class="sr-only peer">
            <span class="px-3 py-1.5 rounded-lg text-sm font-medium border border-gray-200 dark:border-navy-600 bg-white dark:bg-navy-700 text-gray-600 dark:text-gray-300 peer-checked:bg-indigo-500 peer-checked:text-white peer-checked:border-indigo-500 hover:border-indigo-300 dark:hover:border-indigo-500 transition-all">
              <%= MODELING_TYPE_LABELS[type] %>
            </span>
          </label>
        <% }); %>
      </div>
    </div>

    <!-- Row 4: Filtre Tags Métier -->
    <div class="flex flex-wrap items-center gap-2">
      <span class="text-sm font-medium text-gray-500 dark:text-gray-400 flex items-center gap-1.5 min-w-[80px]">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 2 2 7l10 5 10-5-10-5Z"/>
          <path d="m2 17 10 5 10-5"/>
          <path d="m2 12 10 5 10-5"/>
        </svg>
        Domaine
      </span>
      <div class="flex flex-wrap gap-2">
        <% ['iard', 'sante', 'vie', 'pricing', 'reserving', 'fraude', 'machine_learning'].forEach(tag => { %>
          <label class="inline-flex items-center cursor-pointer">
            <input type="checkbox" name="tags" value="<%= tag %>" <%= (filters.tags || '').includes(tag) ? 'checked' : '' %> class="sr-only peer">
            <span class="tag tag-<%= tag %> cursor-pointer opacity-60 peer-checked:opacity-100 peer-checked:ring-2 peer-checked:ring-offset-1 dark:peer-checked:ring-offset-navy-800 peer-checked:ring-current transition-all">
              <%= TAG_LABELS[tag] %>
            </span>
          </label>
        <% }); %>
      </div>
    </div>
  </form>
</div>
