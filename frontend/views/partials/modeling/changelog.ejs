<% if (dataset.changelog && dataset.changelog.length > 0) { %>
<!-- ============================
     CHANGELOG / VERSIONS
     ============================ -->
<div class="card p-6 mb-6">
  <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5 flex items-center gap-2">
    <svg class="w-5 h-5 text-amber-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
    </svg>
    Historique des versions
    <span class="ml-auto text-sm font-normal text-gray-400 dark:text-gray-500"><%= dataset.changelog.length %> version<%= dataset.changelog.length > 1 ? 's' : '' %></span>
  </h2>

  <div class="relative">
    <!-- Ligne verticale de la timeline -->
    <div class="absolute left-[19px] top-2 bottom-2 w-0.5 bg-gray-200 dark:bg-navy-600"></div>

    <div class="space-y-5">
      <% dataset.changelog.slice().reverse().forEach((entry, i) => {
        const isLatest = i === 0;
        const dateObj = new Date(entry.date);
        const dateStr = dateObj.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
        const hashShort = entry.hash ? entry.hash.substring(0, 12) : null;
      %>
      <div class="flex items-start gap-4">
        <!-- Dot -->
        <div class="shrink-0 mt-1 w-10 h-10 rounded-full flex items-center justify-center z-10
          <%= isLatest ? 'bg-amber-100 dark:bg-amber-900/30 ring-2 ring-amber-400 dark:ring-amber-600' : 'bg-gray-100 dark:bg-navy-700' %>">
          <% if (isLatest) { %>
            <svg class="w-4 h-4 text-amber-500" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <% } else { %>
            <svg class="w-4 h-4 text-gray-400 dark:text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4"/></svg>
          <% } %>
        </div>

        <!-- Contenu -->
        <div class="flex-1 pb-5 <%= !isLatest ? 'border-b border-gray-100 dark:border-navy-700' : '' %>">
          <div class="flex items-center gap-2 flex-wrap mb-1">
            <span class="text-sm font-bold font-mono <%= isLatest ? 'text-amber-600 dark:text-amber-400' : 'text-gray-700 dark:text-gray-300' %>">
              <%= entry.version || 'v?' %>
            </span>
            <% if (isLatest) { %>
              <span class="px-2 py-0.5 text-xs font-medium bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 rounded-full">Actuelle</span>
            <% } %>
            <span class="text-xs text-gray-400 dark:text-gray-500 ml-auto"><%= dateStr %></span>
          </div>

          <p class="text-sm text-gray-600 dark:text-gray-300 mb-2"><%= entry.description || '—' %></p>

          <div class="flex flex-wrap items-center gap-3 text-xs text-gray-400 font-mono">
            <% if (entry.size_mb) { %>
            <span class="flex items-center gap-1">
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              <%= entry.size_mb %> MB
            </span>
            <% } %>
            <% if (hashShort) { %>
            <span class="flex items-center gap-1" title="SHA256: <%= entry.hash %>">
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              sha256:<%= hashShort %>…
            </span>
            <% } %>
            <% if (entry.file_url) { %>
            <a href="<%= entry.file_url %>" download class="flex items-center gap-1 text-primary-400 hover:text-primary-500 transition-colors">
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Télécharger cette version
            </a>
            <% } %>
          </div>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</div>
<% } %>
