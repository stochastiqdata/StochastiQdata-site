            num: 4, color: 'violet', icon: 'model',
            title: 'Modélisation',
            goal: 'Entraîner et comparer plusieurs modèles.',
            actions: ['Choisir les features', 'Entraîner baseline', 'Optimiser les hyperparamètres'],
            tools: ['sklearn', 'xgboost', 'statsmodels'], code: 'from sklearn.ensemble import GradientBoostingRegressor\nmodel = GradientBoostingRegressor().fit(X_train, y_train)'
          },
          {
            num: 5, color: 'orange', icon: 'price',
            title: 'Évaluation des performances',
            goal: 'Mesurer la qualité des prédictions avec les bonnes métriques.',
            actions: ['Calculer RMSE, MAE, Gini', 'Courbes de lift', 'SHAP pour l\'interprétabilité'],
            tools: ['sklearn.metrics', 'SHAP'], code: 'from sklearn.metrics import mean_squared_error\nrmse = mean_squared_error(y_test, y_pred, squared=False)'
          },
          {
            num: 6, color: 'red', icon: 'validate',
            title: 'Documentation & Déploiement',
            goal: 'Documenter et industrialiser le modèle.',
            actions: ['Rédiger le rapport technique', 'Exporter le modèle', 'Mettre en place le monitoring'],
            tools: ['joblib', 'mlflow', 'FastAPI'], code: 'import joblib\njoblib.dump(model, "model_v1.pkl")'
          }
        ];
      }

      const stepColors = {
        blue:   { bg: 'bg-blue-100 dark:bg-blue-900/30',   text: 'text-blue-600 dark:text-blue-400',   badge: 'bg-blue-50 dark:bg-blue-900/20 border-blue-200 dark:border-blue-800', tag: 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300' },
        green:  { bg: 'bg-green-100 dark:bg-green-900/30', text: 'text-green-600 dark:text-green-400', badge: 'bg-green-50 dark:bg-green-900/20 border-green-200 dark:border-green-800', tag: 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300' },
        teal:   { bg: 'bg-teal-100 dark:bg-teal-900/30',   text: 'text-teal-600 dark:text-teal-400',   badge: 'bg-teal-50 dark:bg-teal-900/20 border-teal-200 dark:border-teal-800', tag: 'bg-teal-100 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300' },
        violet: { bg: 'bg-violet-100 dark:bg-violet-900/30', text: 'text-violet-600 dark:text-violet-400', badge: 'bg-violet-50 dark:bg-violet-900/20 border-violet-200 dark:border-violet-800', tag: 'bg-violet-100 dark:bg-violet-900/30 text-violet-700 dark:text-violet-300' },
        orange: { bg: 'bg-orange-100 dark:bg-orange-900/30', text: 'text-orange-600 dark:text-orange-400', badge: 'bg-orange-50 dark:bg-orange-900/20 border-orange-200 dark:border-orange-800', tag: 'bg-orange-100 dark:bg-orange-900/30 text-orange-700 dark:text-orange-300' },
        red:    { bg: 'bg-red-100 dark:bg-red-900/30',     text: 'text-red-600 dark:text-red-400',     badge: 'bg-red-50 dark:bg-red-900/20 border-red-200 dark:border-red-800', tag: 'bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-300' }
      };
    %>

    <!-- Barre de progression des étapes -->
    <div class="flex items-center gap-1 mb-4 overflow-x-auto pb-1">
      <% workflowSteps.forEach((step, idx) => { %>
        <% const sc = stepColors[step.color]; %>
        <button
          onclick="scrollToStep(<%= step.num %>)"
          class="flex items-center gap-2 px-3 py-1.5 rounded-lg <%= sc.bg %> <%= sc.text %> text-xs font-semibold shrink-0 hover:opacity-80 transition-opacity cursor-pointer border-none"
        >
          <span class="w-5 h-5 rounded-full <%= sc.bg %> flex items-center justify-center text-xs font-bold"><%= step.num %></span>
          <span class="hidden sm:inline"><%= step.title.split(' ').slice(0, 2).join(' ') %></span>
        </button>
        <% if (idx < workflowSteps.length - 1) { %>
          <svg class="w-3 h-3 text-gray-300 dark:text-navy-600 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <% } %>
      <% }); %>
    </div>

    <!-- Étapes détaillées -->
    <div class="space-y-2">
      <% workflowSteps.forEach((step) => { %>
        <% const sc = stepColors[step.color]; %>
        <div id="step-<%= step.num %>" class="rounded-xl border border-gray-200 dark:border-navy-700 overflow-hidden">

          <!-- En-tête cliquable -->
          <button
            onclick="toggleStep(<%= step.num %>)"
            class="w-full flex items-center gap-3 p-3 text-left hover:bg-gray-50 dark:hover:bg-navy-700/50 transition-colors"
          >
            <!-- Numéro -->
            <div class="w-8 h-8 rounded-lg <%= sc.bg %> flex items-center justify-center shrink-0">
              <span class="<%= sc.text %> font-bold text-sm"><%= step.num %></span>
            </div>

            <!-- Titre + objectif -->
            <div class="flex-1 min-w-0">
              <h3 class="font-semibold text-gray-900 dark:text-white text-sm"><%= step.title %></h3>
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5 truncate"><%= step.goal %></p>
            </div>

            <!-- Outils pills (desktop) -->
            <div class="hidden md:flex items-center gap-1 shrink-0">
              <% step.tools.slice(0, 2).forEach(tool => { %>
                <span class="text-xs px-1.5 py-0.5 rounded <%= sc.tag %>"><%= tool %></span>
              <% }); %>
            </div>

            <!-- Chevron -->
            <svg id="chevron-<%= step.num %>" class="w-4 h-4 text-gray-400 shrink-0 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="m6 9 6 6 6-6"/>
            </svg>
          </button>

          <!-- Contenu dépliable -->
          <div id="content-<%= step.num %>" class="hidden border-t border-gray-100 dark:border-navy-700">
            <div class="p-3 grid md:grid-cols-2 gap-4">

              <!-- Actions concrètes -->
              <div>
                <h4 class="text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-2">Actions concrètes</h4>
                <ul class="space-y-1.5">
                  <% step.actions.forEach(action => { %>
                    <li class="flex items-start gap-2 text-xs text-gray-700 dark:text-gray-300">
                      <svg class="w-3.5 h-3.5 <%= sc.text %> mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                      <%= action %>
                    </li>
                  <% }); %>
                </ul>

                <!-- Outils -->
                <div class="mt-3">
                  <h4 class="text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-1.5">Librairies & outils</h4>
                  <div class="flex flex-wrap gap-1.5">
                    <% step.tools.forEach(tool => { %>
                      <span class="text-xs px-2 py-0.5 rounded-md <%= sc.tag %> font-mono"><%= tool %></span>
                    <% }); %>
                  </div>
                </div>
              </div>

              <!-- Code snippet -->
              <div>
                <h4 class="text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-2">Exemple de code</h4>
                <div class="rounded-lg bg-gray-900 dark:bg-navy-950 p-3 overflow-x-auto">
                  <pre class="text-xs text-green-400 font-mono leading-relaxed whitespace-pre"><%= step.code %></pre>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% }); %>
    </div>

    <!-- Script accordéon -->
    <script>
      function toggleStep(num) {
        const content = document.getElementById('content-' + num);
        const chevron = document.getElementById('chevron-' + num);
        if (content.classList.contains('hidden')) {
          content.classList.remove('hidden');
          chevron.style.transform = 'rotate(180deg)';
        } else {
          content.classList.add('hidden');
          chevron.style.transform = 'rotate(0deg)';
        }
      }
      function scrollToStep(num) {
        const el = document.getElementById('step-' + num);
        if (el) {
          el.scrollIntoView({ behavior: 'smooth', block: 'start' });
          // Ouvrir l'étape si fermée
          const content = document.getElementById('content-' + num);
          if (content && content.classList.contains('hidden')) {
            toggleStep(num);
          }
        }
      }
      // Ouvrir la première étape par défaut
      document.addEventListener('DOMContentLoaded', () => toggleStep(1));
    </script>
  </div>
