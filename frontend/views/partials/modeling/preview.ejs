  <!-- ============================
       APERÇU DES DONNÉES
       ============================ -->
  <% if (dataset.preview_data && dataset.preview_data.length > 0) { %>
  <div class="card p-6 mb-6 overflow-hidden">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
      <svg class="w-5 h-5 text-blue-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
        <line x1="3" y1="9" x2="21" y2="9"/>
        <line x1="3" y1="15" x2="21" y2="15"/>
        <line x1="9" y1="3" x2="9" y2="21"/>
      </svg>
      Aperçu des données — 10 premières lignes
    </h2>
    <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-navy-700">
      <table class="w-full text-sm text-left">
        <thead class="bg-gray-50 dark:bg-navy-700 text-xs text-gray-500 dark:text-gray-400 uppercase tracking-wide">
          <tr>
            <% Object.keys(dataset.preview_data[0]).forEach(col => { %>
              <th class="px-4 py-3 font-semibold whitespace-nowrap"><%= col %></th>
            <% }); %>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-navy-700">
          <% dataset.preview_data.forEach((row, i) => { %>
            <tr class="<%= i % 2 === 0 ? 'bg-white dark:bg-navy-800' : 'bg-gray-50 dark:bg-navy-800/50' %> hover:bg-blue-50 dark:hover:bg-navy-700/50 transition-colors">
              <% Object.values(row).forEach(val => { %>
                <td class="px-4 py-2.5 text-gray-700 dark:text-gray-300 font-mono text-xs whitespace-nowrap"><%= val !== null && val !== undefined ? val : '—' %></td>
              <% }); %>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
  <% } %>
