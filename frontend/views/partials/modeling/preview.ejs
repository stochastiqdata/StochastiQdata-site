<% if (dataset.file_url) { %>
<div class="card p-6 mb-6 overflow-hidden">
  <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
    <svg class="w-5 h-5 text-blue-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
      <line x1="3" y1="9" x2="21" y2="9"/>
      <line x1="3" y1="15" x2="21" y2="15"/>
      <line x1="9" y1="3" x2="9" y2="21"/>
    </svg>
    Aperçu des données
    <span class="text-sm font-normal text-gray-400 dark:text-gray-500">(10 premières lignes)</span>
    <span class="text-xs font-normal text-gray-400 dark:text-gray-500 ml-auto">Cliquez sur une ligne pour l'agrandir</span>
  </h2>

  <div id="previewContainer">
    <div id="previewSkeleton" class="space-y-2">
      <div class="h-8 bg-gray-100 dark:bg-navy-700 rounded-lg animate-pulse"></div>
      <% for(let i = 0; i < 5; i++) { %>
        <div class="h-7 bg-gray-50 dark:bg-navy-800 rounded-lg animate-pulse opacity-<%= 90 - i*15 %>"></div>
      <% } %>
    </div>
    <div id="previewTable" class="hidden overflow-x-auto rounded-xl border border-gray-200 dark:border-navy-700"></div>
    <div id="previewError" class="hidden p-4 text-sm text-red-500 dark:text-red-400 bg-red-50 dark:bg-red-900/10 rounded-xl"></div>
  </div>
</div>

<script>
(function() {
  const datasetId = '<%= dataset.id %>';

  fetch(`/api/datasets/${datasetId}/preview`)
    .then(r => r.json())
    .then(data => {
      document.getElementById('previewSkeleton').classList.add('hidden');

      if (data.detail) {
        const err = document.getElementById('previewError');
        err.textContent = data.detail;
        err.classList.remove('hidden');
        return;
      }

      const cols = data.columns;
      const rows = data.rows;
      const dark = document.documentElement.classList.contains('dark');

      // Couleurs selon mode
      const BG_EVEN   = dark ? '#1e293b' : '#ffffff';
      const BG_ODD    = dark ? '#263349' : '#f8fafc';
      const BG_HOVER  = dark ? '#2f3f58' : '#e8fdf9';
      const BG_EXPAND = dark ? '#1a3a4a' : '#f0fdf9';
      const TXT       = dark ? '#cbd5e1' : '#374151';
      const BORDER    = dark ? '#334155' : '#e2e8f0';

      let html = '<table style="width:100%;font-size:13px;border-collapse:collapse">';

      // En-têtes
      html += '<thead><tr>';
      cols.forEach(col => {
        const typeColor = col.type.includes('float') || col.type.includes('int') ? '#60a5fa' : '#a78bfa';
        html += `<th style="padding:10px 14px;background:${dark?'#334155':'#f1f5f9'};color:${dark?'#e2e8f0':'#374151'};font-weight:600;white-space:nowrap;border-bottom:2px solid ${BORDER};text-align:left">
          <span style="display:block">${col.name}</span>
          <span style="display:block;font-size:11px;font-weight:400;color:${typeColor};margin-top:2px">${col.type}</span>
        </th>`;
      });
      html += '</tr></thead><tbody>';

      rows.forEach((row, i) => {
        const bg = i % 2 === 0 ? BG_EVEN : BG_ODD;
        const rowId = 'pr-detail-' + i;

        // Ligne principale
        html += `<tr id="pr-row-${i}" style="background:${bg};cursor:pointer;transition:background 0.12s"
          onmouseenter="if(!this._open){Array.from(this.cells).forEach(td=>td.style.background='${BG_HOVER}')}"
          onmouseleave="if(!this._open){Array.from(this.cells).forEach(td=>td.style.background='${bg}')}"
          onclick="togglePreviewRow(this,'${rowId}','${bg}','${BG_EXPAND}')">`;

        row.forEach(val => {
          html += `<td style="padding:8px 14px;color:${TXT};font-family:monospace;white-space:nowrap;max-width:180px;overflow:hidden;text-overflow:ellipsis;border-bottom:1px solid ${BORDER}" title="${val}">${val !== '' ? val : '<span style="opacity:0.35">—</span>'}</td>`;
        });
        html += '</tr>';

        // Ligne d'expansion (cachée par défaut)
        html += `<tr id="${rowId}" style="display:none">
          <td colspan="${cols.length}" style="padding:0">
            <div style="padding:16px 20px;background:${BG_EXPAND};border-bottom:2px solid ${dark?'#14b8a6':'#14b8a6'}22">
              <p style="font-size:11px;font-weight:600;color:#14b8a6;margin-bottom:10px;text-transform:uppercase;letter-spacing:0.05em">Ligne ${i+1} — détail complet</p>
              <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:8px">
                ${cols.map((col, j) => `
                  <div style="padding:8px 10px;background:${dark?'rgba(255,255,255,0.04)':'rgba(0,0,0,0.03)'};border-radius:8px;border:1px solid ${BORDER}">
                    <p style="font-size:10px;color:${col.type.includes('float')||col.type.includes('int')?'#60a5fa':'#a78bfa'};font-weight:600;margin-bottom:3px">${col.name}</p>
                    <p style="font-size:13px;color:${TXT};font-family:monospace;word-break:break-all">${row[j] !== '' ? row[j] : '<span style="opacity:0.35">—</span>'}</p>
                  </div>`).join('')}
              </div>
            </div>
          </td>
        </tr>`;
      });

      html += '</tbody></table>';

      const tableDiv = document.getElementById('previewTable');
      tableDiv.innerHTML = html;
      tableDiv.classList.remove('hidden');
    })
    .catch(() => {
      document.getElementById('previewSkeleton').classList.add('hidden');
      const err = document.getElementById('previewError');
      err.textContent = "Impossible de charger l'aperçu.";
      err.classList.remove('hidden');
    });

  window.togglePreviewRow = function(tr, detailId, bgDefault, bgExpand) {
    const detail = document.getElementById(detailId);
    const isOpen = tr._open;
    tr._open = !isOpen;
    detail.style.display = isOpen ? 'none' : 'table-row';
    Array.from(tr.cells).forEach(td => {
      td.style.background = isOpen ? bgDefault : bgExpand;
    });
  };
})();
</script>
<% } %>
