<% if (dataset.file_url) { %>
<div class="card p-6 mb-6 overflow-hidden">
  <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
    <svg class="w-5 h-5 text-blue-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
      <line x1="3" y1="9" x2="21" y2="9"/>
      <line x1="3" y1="15" x2="21" y2="15"/>
      <line x1="9" y1="3" x2="9" y2="21"/>
    </svg>
    Aperçu des données
    <span class="text-sm font-normal text-gray-400 dark:text-gray-500">(10 premières lignes)</span>
  </h2>

  <div id="previewContainer">
    <!-- Skeleton loader -->
    <div id="previewSkeleton" class="space-y-2">
      <div class="h-8 bg-gray-100 dark:bg-navy-700 rounded-lg animate-pulse"></div>
      <% for(let i = 0; i < 5; i++) { %>
        <div class="h-7 bg-gray-50 dark:bg-navy-800 rounded-lg animate-pulse opacity-<%= 90 - i*15 %>"></div>
      <% } %>
    </div>
    <div id="previewTable" class="hidden overflow-x-auto rounded-xl border border-gray-200 dark:border-navy-700"></div>
    <div id="previewError" class="hidden p-4 text-sm text-red-500 dark:text-red-400 bg-red-50 dark:bg-red-900/10 rounded-xl"></div>
  </div>
</div>

<script>
(function() {
  const datasetId = '<%= dataset.id %>';

  fetch(`/api/datasets/${datasetId}/preview`)
    .then(r => r.json())
    .then(data => {
      document.getElementById('previewSkeleton').classList.add('hidden');

      if (data.detail) {
        const err = document.getElementById('previewError');
        err.textContent = data.detail;
        err.classList.remove('hidden');
        return;
      }

      const cols = data.columns;
      const rows = data.rows;

      let html = '<table class="w-full text-sm text-left border-collapse">';

      // En-têtes avec type
      html += '<thead><tr>';
      cols.forEach(col => {
        const typeColor = col.type.includes('float') || col.type.includes('int')
          ? 'text-blue-400' : 'text-purple-400';
        html += `<th class="px-4 py-3 bg-gray-50 dark:bg-navy-700 text-gray-700 dark:text-gray-300 font-semibold whitespace-nowrap border-b border-gray-200 dark:border-navy-600">
          <span class="block">${col.name}</span>
          <span class="block text-xs font-normal ${typeColor} mt-0.5">${col.type}</span>
        </th>`;
      });
      html += '</tr></thead>';

      // Lignes
      html += '<tbody class="divide-y divide-gray-100 dark:divide-navy-700">';
      const isDark = document.documentElement.classList.contains('dark');
      rows.forEach((row, i) => {
        const bgDefault = i % 2 === 0
          ? (isDark ? '#1e293b' : '#ffffff')
          : (isDark ? '#263349' : '#f8fafc');
        const bgHover = isDark ? '#2f3f58' : '#e6faf8';
        const txtColor = isDark ? '#cbd5e1' : '#374151';
        html += `<tr
          onmouseenter="Array.from(this.cells).forEach(td=>{td.style.backgroundColor='${bgHover}'})"
          onmouseleave="Array.from(this.cells).forEach(td=>{td.style.backgroundColor='${bgDefault}'})">`;
        row.forEach(val => {
          html += `<td style="background-color:${bgDefault};color:${txtColor};transition:background-color 0.15s" class="px-4 py-2 font-mono text-xs whitespace-nowrap max-w-[180px] truncate" title="${val}">${val !== '' ? val : '<span style="opacity:0.4">—</span>'}</td>`;
        });
        html += '</tr>';
      });
      html += '</tbody></table>';

      const tableDiv = document.getElementById('previewTable');
      tableDiv.innerHTML = html;
      tableDiv.classList.remove('hidden');
    })
    .catch(() => {
      document.getElementById('previewSkeleton').classList.add('hidden');
      const err = document.getElementById('previewError');
      err.textContent = "Impossible de charger l'aperçu.";
      err.classList.remove('hidden');
    });
})();
</script>
<% } %>
