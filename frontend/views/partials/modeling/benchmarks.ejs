  <!-- ============================
       BENCHMARKS
       ============================ -->
  <div class="card p-6 mb-6">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
      <svg class="w-5 h-5 text-orange-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
      </svg>
      Benchmarks — Performance des modèles
    </h2>
    <%
      const benchmarks = locals.benchmarks || [];
    %>
    <% if (benchmarks.length > 0) { %>
      <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-navy-700">
        <table class="w-full text-sm text-left">
          <thead class="bg-gray-50 dark:bg-navy-700 text-xs text-gray-500 dark:text-gray-400 uppercase tracking-wide">
            <tr>
              <th class="px-4 py-3 font-semibold">Modèle</th>
              <th class="px-4 py-3 font-semibold">Métrique</th>
              <th class="px-4 py-3 font-semibold">Score</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-navy-700">
            <% benchmarks.forEach((b, i) => { %>
              <tr class="<%= i % 2 === 0 ? 'bg-white dark:bg-navy-800' : 'bg-gray-50 dark:bg-navy-800/50' %>">
                <td class="px-4 py-2.5 font-medium text-gray-900 dark:text-white"><%= MODEL_LABELS[b.model_type] || b.model_type %></td>
                <td class="px-4 py-2.5 text-gray-600 dark:text-gray-400"><%= b.metric_type %></td>
                <td class="px-4 py-2.5">
                  <span class="font-mono font-semibold text-orange-600 dark:text-orange-400"><%= b.score %></span>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="flex flex-col items-center justify-center py-10 text-center">
        <div class="w-14 h-14 rounded-2xl bg-orange-100 dark:bg-orange-900/20 flex items-center justify-center mb-4">
          <svg class="w-7 h-7 text-orange-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
          </svg>
        </div>
        <p class="text-gray-500 dark:text-gray-400 text-sm">Aucun benchmark disponible pour ce dataset.</p>
        <p class="text-gray-400 dark:text-gray-500 text-xs mt-1">Soyez le premier à soumettre vos résultats !</p>
      </div>
    <% } %>
  </div>
