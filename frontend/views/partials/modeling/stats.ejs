<% if (dataset.file_url) { %>
<!-- ============================
     STATISTIQUES & PROFIL
     ============================ -->
<div class="card p-6 mb-6">
  <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
    <svg class="w-5 h-5 text-violet-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <rect x="3" y="3" width="18" height="18" rx="2"/>
      <path d="M3 9h18M9 21V9"/>
    </svg>
    Statistiques & Profil des données
  </h2>

  <!-- Profil global skeleton -->
  <div id="statsProfileSkeleton" class="grid grid-cols-2 md:grid-cols-6 gap-3 mb-6">
    <% for(let i = 0; i < 6; i++) { %>
      <div class="h-16 bg-gray-100 dark:bg-navy-700 rounded-xl animate-pulse"></div>
    <% } %>
  </div>

  <!-- Profil global (rempli dynamiquement) -->
  <div id="statsProfile" class="hidden grid grid-cols-2 md:grid-cols-6 gap-3 mb-6"></div>

  <!-- Table skeleton -->
  <div id="statsTableSkeleton" class="space-y-2">
    <div class="h-8 bg-gray-100 dark:bg-navy-700 rounded-lg animate-pulse"></div>
    <% for(let i = 0; i < 6; i++) { %>
      <div class="h-10 bg-gray-50 dark:bg-navy-800 rounded-lg animate-pulse"></div>
    <% } %>
  </div>

  <!-- Table des stats (remplie dynamiquement) -->
  <div id="statsTable" class="hidden"></div>

  <div id="statsError" class="hidden p-4 text-sm text-red-500 bg-red-50 dark:bg-red-900/10 rounded-xl"></div>
</div>

<script>
(function() {
  const datasetId = '<%= dataset.id %>';

  fetch(`/api/datasets/${datasetId}/stats`)
    .then(r => r.json())
    .then(data => {
      document.getElementById('statsProfileSkeleton').classList.add('hidden');
      document.getElementById('statsTableSkeleton').classList.add('hidden');

      if (data.detail) {
        const err = document.getElementById('statsError');
        err.textContent = data.detail;
        err.classList.remove('hidden');
        return;
      }

      const p = data.profile;

      // ---- Profil global ----
      const profileItems = [
        { label: 'Observations', value: p.total_rows.toLocaleString('fr-FR'), color: 'blue' },
        { label: 'Variables', value: p.total_cols, color: 'violet' },
        { label: 'Numériques', value: p.numeric_count, color: 'green' },
        { label: 'Catégorielles', value: p.categorical_count, color: 'orange' },
        { label: 'Nulls global', value: p.overall_null_pct + '%', color: p.overall_null_pct > 10 ? 'red' : p.overall_null_pct > 0 ? 'amber' : 'teal' },
        { label: 'Variable cible', value: p.suggested_target || '—', color: 'primary' },
      ];

      const colorMap = {
        blue: 'bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 text-blue-500',
        violet: 'bg-violet-50 dark:bg-violet-900/20 text-violet-600 dark:text-violet-400',
        green: 'bg-green-50 dark:bg-green-900/20 text-green-600 dark:text-green-400',
        orange: 'bg-orange-50 dark:bg-orange-900/20 text-orange-600 dark:text-orange-400',
        red: 'bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400',
        amber: 'bg-amber-50 dark:bg-amber-900/20 text-amber-600 dark:text-amber-400',
        teal: 'bg-teal-50 dark:bg-teal-900/20 text-teal-600 dark:text-teal-400',
        primary: 'bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400',
      };

      const profileEl = document.getElementById('statsProfile');
      profileEl.innerHTML = profileItems.map(item => {
        const c = colorMap[item.color] || colorMap.blue;
        return `<div class="rounded-xl p-3 text-center ${c.split(' ').slice(0,2).join(' ')}">
          <p class="text-lg font-bold ${c.split(' ').slice(2).join(' ')} truncate" title="${item.value}">${item.value}</p>
          <p class="text-xs mt-0.5 opacity-80">${item.label}</p>
        </div>`;
      }).join('');
      profileEl.classList.remove('hidden');

      // ---- Table des colonnes ----
      let html = `<div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-navy-700">
        <table class="w-full text-sm text-left">
          <thead class="bg-gray-50 dark:bg-navy-700 text-xs text-gray-500 dark:text-gray-400 uppercase tracking-wide">
            <tr>
              <th class="px-4 py-3 font-semibold">Variable</th>
              <th class="px-4 py-3 font-semibold">Type</th>
              <th class="px-4 py-3 font-semibold">Null %</th>
              <th class="px-4 py-3 font-semibold">Unique</th>
              <th class="px-4 py-3 font-semibold">Statistiques</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-navy-700">`;

      data.columns.forEach((col, i) => {
        const bg = i % 2 === 0 ? 'tr-even' : 'tr-odd';
        const typeLabel = col.is_numeric
          ? `<span class="px-2 py-0.5 rounded-md text-xs font-medium bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300">${col.dtype}</span>`
          : `<span class="px-2 py-0.5 rounded-md text-xs font-medium bg-violet-100 dark:bg-violet-900/30 text-violet-700 dark:text-violet-300">${col.dtype}</span>`;

        const nullColor = col.null_pct > 10 ? 'text-red-500' : col.null_pct > 0 ? 'text-amber-500' : 'text-green-500';
        const nullBarColor = col.null_pct > 10 ? 'bg-red-500' : col.null_pct > 0 ? 'bg-amber-400' : 'bg-green-500';
        const completeness = 100 - col.null_pct;

        const nullCell = `<div class="flex items-center gap-2">
          <div class="w-14 h-1.5 bg-gray-200 dark:bg-navy-600 rounded-full overflow-hidden">
            <div class="h-full rounded-full ${nullBarColor}" style="width:${completeness}%"></div>
          </div>
          <span class="text-xs font-mono ${nullColor}">${col.null_pct}%</span>
        </div>`;

        let statsCell = '';
        if (col.is_numeric) {
          const range = (col.max - col.min) || 1;
          const p25pos = Math.round(((col.p25 - col.min) / range) * 100);
          const p75pos = Math.round(((col.p75 - col.min) / range) * 100);
          const medpos = Math.round(((col.p50 - col.min) / range) * 100);
          statsCell = `<div class="space-y-1">
            <div class="flex gap-3 text-xs font-mono text-gray-500 dark:text-gray-400">
              <span title="Min">▼ ${col.min}</span>
              <span title="Moyenne" class="text-primary-500">⌀ ${col.mean}</span>
              <span title="Médiane">~ ${col.p50}</span>
              <span title="Max">▲ ${col.max}</span>
              <span title="Écart-type" class="text-gray-400">σ ${col.std}</span>
            </div>
            <div class="relative h-2 bg-gray-200 dark:bg-navy-600 rounded-full w-48">
              <div class="absolute h-full bg-blue-200 dark:bg-blue-900/50 rounded-full" style="left:${p25pos}%;width:${p75pos-p25pos}%"></div>
              <div class="absolute w-0.5 h-full bg-blue-500" style="left:${medpos}%"></div>
            </div>
          </div>`;
        } else {
          const topValues = (col.top_values || []);
          const maxCount = topValues[0]?.count || 1;
          statsCell = `<div class="space-y-0.5">
            ${topValues.slice(0, 3).map(v => {
              const pct = Math.round((v.count / maxCount) * 100);
              return `<div class="flex items-center gap-2">
                <span class="text-xs text-gray-600 dark:text-gray-300 font-mono w-16 truncate" title="${v.value}">${v.value}</span>
                <div class="flex-1 h-1.5 bg-gray-200 dark:bg-navy-600 rounded-full max-w-[80px]">
                  <div class="h-full bg-violet-400 rounded-full" style="width:${pct}%"></div>
                </div>
                <span class="text-xs text-gray-400">${v.count.toLocaleString('fr-FR')}</span>
              </div>`;
            }).join('')}
          </div>`;
        }

        html += `<tr class="${bg} transition-colors">
          <td class="px-4 py-3 font-mono text-xs font-semibold text-violet-700 dark:text-violet-300 whitespace-nowrap">${col.name}</td>
          <td class="px-4 py-3">${typeLabel}</td>
          <td class="px-4 py-3">${nullCell}</td>
          <td class="px-4 py-3 text-xs text-gray-500 dark:text-gray-400 font-mono">${col.unique.toLocaleString('fr-FR')}</td>
          <td class="px-4 py-3">${statsCell}</td>
        </tr>`;
      });

      html += '</tbody></table></div>';
      const tableEl = document.getElementById('statsTable');
      tableEl.innerHTML = html;
      tableEl.classList.remove('hidden');

      // Partage des données avec les autres sections (distributions)
      window._statsData = data;
      document.dispatchEvent(new CustomEvent('statsLoaded', { detail: data }));
    })
    .catch(() => {
      document.getElementById('statsProfileSkeleton').classList.add('hidden');
      document.getElementById('statsTableSkeleton').classList.add('hidden');
      const err = document.getElementById('statsError');
      err.textContent = "Impossible de charger les statistiques.";
      err.classList.remove('hidden');
    });
})();
</script>
<% } %>
