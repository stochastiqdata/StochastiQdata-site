  <!-- Breadcrumb -->
  <nav class="mb-6">
    <div class="flex items-center gap-2 text-sm">
      <a href="/" class="text-gray-500 hover:text-primary-500 transition-colors">Dashboard</a>
      <svg class="w-4 h-4 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/modelisation" class="text-gray-500 hover:text-primary-500 transition-colors">Modélisation</a>
      <svg class="w-4 h-4 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-gray-900 dark:text-white font-medium truncate max-w-[200px]"><%= dataset.name %></span>
    </div>
  </nav>

  <!-- Header du dataset -->
  <div class="card p-6 mb-6">
    <div class="flex items-start justify-between gap-6">
      <div class="flex-1">
        <div class="flex items-center gap-3 mb-2">
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= dataset.name %></h1>
          <span class="badge badge-<%= dataset.source %>"><%= SOURCE_LABELS[dataset.source] %></span>
        </div>

        <% if (dataset.description) { %>
          <p class="text-gray-600 dark:text-gray-400 mb-4"><%= dataset.description %></p>
        <% } %>

        <!-- Tags -->
        <div class="flex flex-wrap gap-2 mb-4">
          <% (dataset.tags || []).forEach(tag => { %>
            <span class="tag tag-<%= tag %>"><%= TAG_LABELS[tag] || tag %></span>
          <% }); %>
        </div>

        <!-- Boutons d'action -->
        <div class="flex flex-wrap gap-2">
          <% var colabUrl = dataset.colab_url || 'https://colab.research.google.com/#create=true'; %>
          <a href="<%= colabUrl %>" target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-amber-500 hover:bg-amber-600 text-white font-semibold text-sm transition-all shadow-md hover:scale-[1.02]">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
              <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
            </svg>
            Open in Colab
          </a>

          <% if (dataset.file_url) { %>
            <button onclick="trackAndDownload('<%= dataset.id %>', '<%= dataset.file_url %>')"
               class="inline-flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-primary-500 to-teal-500 hover:from-primary-600 hover:to-teal-600 text-white font-semibold text-sm rounded-xl transition-all shadow-md hover:scale-[1.02]">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
              </svg>
              Télécharger
              <span id="dlCountBadge" class="text-xs opacity-75"><% if (dataset.download_count > 0) { %>· <%= dataset.download_count.toLocaleString('fr-FR') %><% } %></span>
            </button>
          <% } %>

          <% if (dataset.source_url) { %>
            <a href="<%= dataset.source_url %>" target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 dark:bg-navy-700 hover:bg-gray-200 dark:hover:bg-navy-600 text-gray-700 dark:text-gray-300 font-medium text-sm rounded-xl transition-all">
              <% if (dataset.source === 'kaggle') { %>
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
                </svg>
                Open in Kaggle
              <% } else { %>
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                Source externe
              <% } %>
            </a>
          <% } %>

          <% if (dataset.data_dictionary_url) { %>
            <a href="<%= dataset.data_dictionary_url %>" target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 dark:bg-navy-700 hover:bg-gray-200 dark:hover:bg-navy-600 text-gray-700 dark:text-gray-300 font-medium text-sm rounded-xl transition-all">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
              </svg>
              Documentation
            </a>
          <% } %>

          <a href="/compare?a=<%= dataset.id %>"
             class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 dark:bg-navy-700 hover:bg-gray-200 dark:hover:bg-navy-600 text-gray-700 dark:text-gray-300 font-medium text-sm rounded-xl transition-all">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="3" width="9" height="18" rx="2"/><rect x="13" y="3" width="9" height="18" rx="2"/>
            </svg>
            Comparer
          </a>

          <% if (!dataset.file_url) { %>
            <button onclick="document.getElementById('uploadFileZone').classList.toggle('hidden')"
               class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 dark:bg-navy-700 hover:bg-gray-200 dark:hover:bg-navy-600 text-gray-700 dark:text-gray-300 font-medium text-sm rounded-xl transition-all border-2 border-dashed border-gray-300 dark:border-navy-500">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="17 8 12 3 7 8"/>
                <line x1="12" y1="3" x2="12" y2="15"/>
              </svg>
              Uploader le fichier
            </button>
          <% } %>
        </div>

        <!-- Zone upload inline (masquée par défaut) -->
        <div id="uploadFileZone" class="hidden mt-4 p-4 rounded-xl bg-gray-50 dark:bg-navy-700 border border-dashed border-gray-300 dark:border-navy-500">
          <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Uploader le fichier (CSV, Parquet, Excel — max 50 MB)</p>
          <div class="flex items-center gap-3">
            <input type="file" id="datasetFileInput" accept=".csv,.parquet,.xlsx,.xls"
              class="flex-1 text-sm text-gray-600 dark:text-gray-300 file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-primary-500 file:text-white file:font-medium file:cursor-pointer hover:file:bg-primary-600">
            <button id="uploadFileBtn" onclick="uploadDatasetFile('<%= dataset.id %>')"
              class="px-4 py-2 bg-primary-500 hover:bg-primary-600 text-white font-medium text-sm rounded-xl transition-all">
              Envoyer
            </button>
          </div>
          <p id="uploadFileMsg" class="hidden mt-2 text-sm"></p>
        </div>
      </div>

      <!-- Grand cercle de score -->
      <div class="score-circle shrink-0 relative group" title="Score: <%= score %>/100">
        <!-- Tooltip explicatif -->
        <div class="absolute right-0 top-full mt-2 w-56 bg-gray-900 dark:bg-navy-700 text-white text-xs rounded-xl p-3 shadow-xl opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-50" style="min-width:220px">
          <p class="font-semibold text-teal-300 mb-2">Score qualité — <%= score %>/100</p>
          <ul class="space-y-1 text-gray-300">
            <li>· Complétude des métadonnées</li>
            <li>· Taux de valeurs nulles</li>
            <li>· Présence d'un dictionnaire</li>
            <li>· Avis et téléchargements</li>
            <li>· Disponibilité des benchmarks</li>
          </ul>
        </div>
        <svg width="100" height="100" viewBox="0 0 80 80">
          <circle cx="40" cy="40" r="36" fill="none" stroke="#E5E7EB" stroke-width="6"/>
          <defs>
            <linearGradient id="scoreGradientLarge" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#3B82F6"/>
              <stop offset="100%" stop-color="#22C55E"/>
            </linearGradient>
          </defs>
          <circle cx="40" cy="40" r="36" fill="none" stroke="url(#scoreGradientLarge)" stroke-width="6" stroke-linecap="round" stroke-dasharray="<%= circumference %>" stroke-dashoffset="<%= strokeDashoffset %>"/>
        </svg>
        <span class="score-value text-2xl font-bold text-gray-900 dark:text-white"><%= score %></span>
      </div><!-- /score-circle -->
    </div>
  </div>

<script>
async function trackAndDownload(datasetId, fallbackUrl) {
  try {
    const res = await fetch(`/api/datasets/${datasetId}/download`, { method: 'POST' });
    const data = await res.json();
    const url = data.file_url || fallbackUrl;
    const badge = document.getElementById('dlCountBadge');
    if (badge && data.download_count) {
      badge.textContent = '· ' + data.download_count.toLocaleString('fr-FR');
    }
    const a = document.createElement('a');
    a.href = url;
    a.download = '';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
  } catch {
    window.location.href = fallbackUrl;
  }
}

async function uploadDatasetFile(datasetId) {
  const input = document.getElementById('datasetFileInput');
  const btn = document.getElementById('uploadFileBtn');
  const msg = document.getElementById('uploadFileMsg');

  if (!input.files?.length) {
    msg.textContent = 'Sélectionne un fichier d\'abord.';
    msg.className = 'mt-2 text-sm text-red-500';
    msg.classList.remove('hidden');
    return;
  }

  btn.disabled = true;
  btn.textContent = 'Envoi...';
  msg.classList.add('hidden');

  const form = new FormData();
  form.append('file', input.files[0]);

  try {
    const res = await fetch(`/api/datasets/${datasetId}/upload-file`, {
      method: 'POST',
      body: form
    });

    if (!res.ok) {
      const err = await res.json();
      throw new Error(err.detail || 'Erreur upload');
    }

    msg.textContent = 'Fichier uploadé avec succès ! Rechargement...';
    msg.className = 'mt-2 text-sm text-green-600 dark:text-green-400';
    msg.classList.remove('hidden');
    setTimeout(() => location.reload(), 1500);
  } catch (e) {
    msg.textContent = e.message;
    msg.className = 'mt-2 text-sm text-red-500';
    msg.classList.remove('hidden');
    btn.disabled = false;
    btn.textContent = 'Envoyer';
  }
}
</script>
