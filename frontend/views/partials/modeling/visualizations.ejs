<!-- ============================
     VISUALISATIONS DES DONNÉES
     ============================ -->
<div class="card p-6 mb-6" id="vizSection">
  <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-1 flex items-center gap-2">
    <svg class="w-5 h-5 text-green-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/>
      <line x1="6" y1="20" x2="6" y2="14"/>
    </svg>
    Visualisations des données
  </h2>
  <p class="text-xs text-gray-400 dark:text-gray-500 mb-5">Basées sur les données réelles du dataset</p>

  <!-- Loading -->
  <div id="vizLoading" class="flex items-center gap-2 text-sm text-gray-400 dark:text-gray-500">
    <svg class="w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
    </svg>
    Chargement…
  </div>

  <div id="vizGrid" class="hidden grid md:grid-cols-3 gap-4"></div>
  <div id="vizEmpty" class="hidden text-sm text-gray-400 dark:text-gray-500">Aucune donnée disponible pour générer des visualisations.</div>
</div>

<script>
(function () {
  var isDark = document.documentElement.classList.contains('dark');
  var grid  = isDark ? 'rgba(255,255,255,0.07)' : 'rgba(0,0,0,0.06)';
  var tick  = isDark ? '#94a3b8' : '#64748b';
  var baseOpts = {
    responsive: true,
    plugins: { legend: { display: false } },
    scales: {
      x: { grid: { color: grid }, ticks: { color: tick, font: { size: 10 }, maxRotation: 45 } },
      y: { grid: { color: grid }, ticks: { color: tick, font: { size: 10 } } }
    }
  };

  var PALETTE = ['#3b82f6','#6366f1','#8b5cf6','#a855f7','#ec4899','#f43f5e','#f97316','#eab308','#22c55e','#14b8a6'];

  function buildChart(canvasId, type, data, opts) {
    var el = document.getElementById(canvasId);
    if (!el || !window.Chart) return;
    new Chart(el, { type: type, data: data, options: opts || baseOpts });
  }

  function makePanelHtml(id, title) {
    return '<div class="rounded-xl border border-gray-200 dark:border-navy-700 p-4">'
      + '<p class="text-xs font-semibold text-gray-600 dark:text-gray-400 mb-3">' + title + '</p>'
      + '<canvas id="' + id + '" height="190"></canvas>'
      + '</div>';
  }

  var TARGET_VIZ = '<%= dataset.target_variable || "" %>';

  function pickBestColumns(columns) {
    var numeric = columns.filter(function(c) { return c.is_numeric && c.histogram; });
    var categ   = columns.filter(function(c) { return !c.is_numeric && c.top_values && c.top_values.length > 1; });

    // Variable cible en priorité absolue
    var targetNum  = numeric.find(function(c) { return c.name === TARGET_VIZ; });
    var targetCat  = categ.find(function(c)   { return c.name === TARGET_VIZ; });
    var otherNum   = numeric.filter(function(c) { return c.name !== TARGET_VIZ; });
    var otherCat   = categ.filter(function(c)   { return c.name !== TARGET_VIZ; });

    var selected = [];
    if (targetNum) selected.push({ col: targetNum, type: 'num', isTarget: true });
    if (targetCat) selected.push({ col: targetCat, type: 'cat', isTarget: true });
    if (selected.length < 3 && otherNum.length > 0) selected.push({ col: otherNum[0], type: 'num' });
    if (selected.length < 3 && otherCat.length > 0) selected.push({ col: otherCat[0], type: 'cat' });
    if (selected.length < 3 && otherNum.length > 1) selected.push({ col: otherNum[1], type: 'num' });
    if (selected.length < 3 && otherCat.length > 1) selected.push({ col: otherCat[1], type: 'cat' });

    return selected.slice(0, 3);
  }

  function renderNumChart(canvasId, col) {
    var h = col.histogram;
    var edges = h.edges;
    var labels = h.counts.map(function(_, i) {
      var lo = edges[i], hi = edges[i + 1];
      if (Math.abs(lo) < 10 && Math.abs(hi) < 10) {
        return lo.toFixed(2) + '–' + hi.toFixed(2);
      }
      return lo.toFixed(0) + '–' + hi.toFixed(0);
    });
    var total = h.counts.reduce(function(a, b) { return a + b; }, 0);
    var pcts = h.counts.map(function(v) { return total > 0 ? parseFloat((v / total * 100).toFixed(2)) : 0; });

    buildChart(canvasId, 'bar', {
      labels: labels,
      datasets: [{ data: pcts, backgroundColor: '#3b82f6', borderRadius: 4 }]
    }, Object.assign({}, baseOpts, {
      scales: {
        x: Object.assign({}, baseOpts.scales.x, { ticks: { color: tick, font: { size: 9 }, maxRotation: 45, maxTicksLimit: 10 } }),
        y: Object.assign({}, baseOpts.scales.y, {
          ticks: Object.assign({}, baseOpts.scales.y.ticks, { callback: function(v) { return v + '%'; } })
        })
      },
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: function(c) { return c.raw + '%'; } } } }
    }));
  }

  function renderCategChart(canvasId, col) {
    var top = col.top_values.slice(0, 8);
    var total = top.reduce(function(a, b) { return a + b.count; }, 0);
    var labels = top.map(function(t) { return String(t.value); });
    var pcts   = top.map(function(t) { return parseFloat((t.count / total * 100).toFixed(1)); });

    buildChart(canvasId, 'bar', {
      labels: labels,
      datasets: [{ data: pcts, backgroundColor: top.map(function(_, i) { return PALETTE[i % PALETTE.length]; }), borderRadius: 4 }]
    }, Object.assign({}, baseOpts, {
      scales: {
        x: Object.assign({}, baseOpts.scales.x, { ticks: { color: tick, font: { size: 9 }, maxRotation: 45 } }),
        y: Object.assign({}, baseOpts.scales.y, {
          ticks: Object.assign({}, baseOpts.scales.y.ticks, { callback: function(v) { return v + '%'; } })
        })
      },
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: function(c) { return c.raw + '%'; } } } }
    }));
  }

  function renderViz(data) {
    var cols = data.columns || [];
    if (!cols.length) {
      document.getElementById('vizLoading').classList.add('hidden');
      document.getElementById('vizEmpty').classList.remove('hidden');
      return;
    }

    var picks = pickBestColumns(cols);
    if (!picks.length) {
      document.getElementById('vizLoading').classList.add('hidden');
      document.getElementById('vizEmpty').classList.remove('hidden');
      return;
    }

    var html = picks.map(function(p, i) {
      var label = p.type === 'num' ? ' — distribution' : ' — top valeurs';
      var targetBadge = p.isTarget ? ' <span style="font-size:10px;padding:1px 6px;background:#0d9488;color:#fff;border-radius:4px;font-weight:600;vertical-align:middle">cible</span>' : '';
      return makePanelHtml('viz-real-' + i, p.col.name + label + targetBadge);
    }).join('');

    var vizGrid = document.getElementById('vizGrid');
    vizGrid.innerHTML = html;
    document.getElementById('vizLoading').classList.add('hidden');
    vizGrid.classList.remove('hidden');

    picks.forEach(function(p, i) {
      if (p.type === 'num') {
        renderNumChart('viz-real-' + i, p.col);
      } else {
        renderCategChart('viz-real-' + i, p.col);
      }
    });
  }

  // Écoute les stats si déjà chargées ou en attente
  if (window._statsData) {
    renderViz(window._statsData);
  } else {
    document.addEventListener('statsLoaded', function(e) {
      renderViz(e.detail);
    }, { once: true });
  }
})();
</script>
