<!-- ============================
     HUB DES MODÈLES ACTUARIELS
     ============================ -->
<div class="mb-10">
  <h2 class="text-2xl font-semibold text-gray-900 dark:text-white mb-1">Modèles actuariels</h2>
  <p class="text-gray-500 dark:text-gray-400 text-sm mb-6">Les modèles de référence en assurance non-vie, vie, et ML actuariel.</p>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">

    <!-- GLM Poisson -->
    <div class="card p-5 hover:border-blue-400 dark:hover:border-blue-500 border border-transparent transition-colors cursor-pointer">
      <div class="flex items-start justify-between mb-3">
        <div class="w-10 h-10 rounded-xl bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center">
          <svg class="w-5 h-5 text-blue-600 dark:text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
        </div>
        <span class="text-xs px-2 py-0.5 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 font-medium">GLM</span>
      </div>
      <h3 class="font-semibold text-gray-900 dark:text-white mb-1">GLM Poisson</h3>
      <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">Modèle linéaire généralisé pour la fréquence des sinistres. Utilise une loi de Poisson avec un lien logarithmique.</p>
      <div class="flex flex-wrap gap-1.5 mb-3">
        <span class="tag tag-iard text-xs">IARD</span>
        <span class="tag tag-pricing text-xs">Pricing</span>
      </div>
      <div class="pt-3 border-t border-gray-100 dark:border-navy-700 flex items-center justify-between">
        <span class="text-xs text-gray-400 font-mono">Métrique : D², AIC</span>
        <a href="#demo-glm-poisson" class="text-xs text-blue-500 hover:underline font-medium">Voir démo ↓</a>
      </div>
    </div>

    <!-- GLM Gamma -->
    <div class="card p-5 hover:border-orange-400 dark:hover:border-orange-500 border border-transparent transition-colors cursor-pointer">
      <div class="flex items-start justify-between mb-3">
        <div class="w-10 h-10 rounded-xl bg-orange-100 dark:bg-orange-900/30 flex items-center justify-center">
          <svg class="w-5 h-5 text-orange-600 dark:text-orange-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg>
        </div>
        <span class="text-xs px-2 py-0.5 rounded-full bg-orange-100 dark:bg-orange-900/30 text-orange-700 dark:text-orange-300 font-medium">GLM</span>
      </div>
      <h3 class="font-semibold text-gray-900 dark:text-white mb-1">GLM Gamma</h3>
      <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">Modèle pour le coût moyen conditionnel d'un sinistre. Distribution Gamma, lien logarithmique, données positives asymétriques.</p>
      <div class="flex flex-wrap gap-1.5 mb-3">
        <span class="tag tag-iard text-xs">IARD</span>
        <span class="tag tag-pricing text-xs">Pricing</span>
      </div>
      <div class="pt-3 border-t border-gray-100 dark:border-navy-700 flex items-center justify-between">
        <span class="text-xs text-gray-400 font-mono">Métrique : D², Gini</span>
        <a href="#demo-glm-gamma" class="text-xs text-orange-500 hover:underline font-medium">Voir démo ↓</a>
      </div>
    </div>

    <!-- Tweedie -->
    <div class="card p-5 hover:border-violet-400 dark:hover:border-violet-500 border border-transparent transition-colors cursor-pointer">
      <div class="flex items-start justify-between mb-3">
        <div class="w-10 h-10 rounded-xl bg-violet-100 dark:bg-violet-900/30 flex items-center justify-center">
          <svg class="w-5 h-5 text-violet-600 dark:text-violet-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        </div>
        <span class="text-xs px-2 py-0.5 rounded-full bg-violet-100 dark:bg-violet-900/30 text-violet-700 dark:text-violet-300 font-medium">GLM</span>
      </div>
      <h3 class="font-semibold text-gray-900 dark:text-white mb-1">Tweedie (Prime pure)</h3>
      <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">Combine fréquence et coût en un seul modèle. Paramètre p (1 &lt; p &lt; 2) contrôle le compromis Poisson-Gamma.</p>
      <div class="flex flex-wrap gap-1.5 mb-3">
        <span class="tag tag-iard text-xs">IARD</span>
        <span class="tag tag-pricing text-xs">Pricing</span>
      </div>
      <div class="pt-3 border-t border-gray-100 dark:border-navy-700 flex items-center justify-between">
        <span class="text-xs text-gray-400 font-mono">Métrique : D² Tweedie</span>
        <a href="#demo-tweedie" class="text-xs text-violet-500 hover:underline font-medium">Voir démo ↓</a>
      </div>
    </div>

    <!-- Chain Ladder -->
    <div class="card p-5 hover:border-teal-400 dark:hover:border-teal-500 border border-transparent transition-colors cursor-pointer">
      <div class="flex items-start justify-between mb-3">
        <div class="w-10 h-10 rounded-xl bg-teal-100 dark:bg-teal-900/30 flex items-center justify-center">
          <svg class="w-5 h-5 text-teal-600 dark:text-teal-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 22 22 2 22"/></svg>
        </div>
        <span class="text-xs px-2 py-0.5 rounded-full bg-teal-100 dark:bg-teal-900/30 text-teal-700 dark:text-teal-300 font-medium">Reserving</span>
      </div>
      <h3 class="font-semibold text-gray-900 dark:text-white mb-1">Chain Ladder</h3>
      <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">Méthode de provisionnement IBNR via triangles de développement. Estime les sinistres tardifs à partir des facteurs de développement.</p>
      <div class="flex flex-wrap gap-1.5 mb-3">
        <span class="tag tag-reserving text-xs">Reserving</span>
        <span class="tag tag-iard text-xs">IARD</span>
      </div>
      <div class="pt-3 border-t border-gray-100 dark:border-navy-700 flex items-center justify-between">
        <span class="text-xs text-gray-400 font-mono">Métrique : IBNR, LDF</span>
        <a href="#demo-chain-ladder" class="text-xs text-teal-500 hover:underline font-medium">Voir démo ↓</a>
      </div>
    </div>

    <!-- Kaplan-Meier -->
    <div class="card p-5 hover:border-pink-400 dark:hover:border-pink-500 border border-transparent transition-colors cursor-pointer">
      <div class="flex items-start justify-between mb-3">
        <div class="w-10 h-10 rounded-xl bg-pink-100 dark:bg-pink-900/30 flex items-center justify-center">
          <svg class="w-5 h-5 text-pink-600 dark:text-pink-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        </div>
        <span class="text-xs px-2 py-0.5 rounded-full bg-pink-100 dark:bg-pink-900/30 text-pink-700 dark:text-pink-300 font-medium">Survie</span>
      </div>
      <h3 class="font-semibold text-gray-900 dark:text-white mb-1">Kaplan-Meier</h3>
      <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">Estimateur non paramétrique de la fonction de survie. Gère les données censurées, fondamental en actuariat vie.</p>
      <div class="flex flex-wrap gap-1.5 mb-3">
        <span class="tag tag-vie text-xs">Vie</span>
      </div>
      <div class="pt-3 border-t border-gray-100 dark:border-navy-700 flex items-center justify-between">
        <span class="text-xs text-gray-400 font-mono">Métrique : Log-rank</span>
        <a href="#demo-kaplan-meier" class="text-xs text-pink-500 hover:underline font-medium">Voir démo ↓</a>
      </div>
    </div>

    <!-- XGBoost -->
    <div class="card p-5 hover:border-green-400 dark:hover:border-green-500 border border-transparent transition-colors cursor-pointer">
      <div class="flex items-start justify-between mb-3">
        <div class="w-10 h-10 rounded-xl bg-green-100 dark:bg-green-900/30 flex items-center justify-center">
          <svg class="w-5 h-5 text-green-600 dark:text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        </div>
        <span class="text-xs px-2 py-0.5 rounded-full bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 font-medium">ML</span>
      </div>
      <h3 class="font-semibold text-gray-900 dark:text-white mb-1">XGBoost</h3>
      <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">Gradient boosting sur arbres. Très performant pour la détection de fraude et la tarification non-linéaire.</p>
      <div class="flex flex-wrap gap-1.5 mb-3">
        <span class="tag tag-fraude text-xs">Fraude</span>
        <span class="tag tag-iard text-xs">IARD</span>
      </div>
      <div class="pt-3 border-t border-gray-100 dark:border-navy-700 flex items-center justify-between">
        <span class="text-xs text-gray-400 font-mono">Métrique : AUC, F1</span>
        <a href="#demo-xgboost" class="text-xs text-green-500 hover:underline font-medium">Voir démo ↓</a>
      </div>
    </div>

  </div>
</div>
