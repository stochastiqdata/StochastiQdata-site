<!DOCTYPE html>
<html lang="fr" class="">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <!-- ── Titre dynamique ── -->
  <title><%= typeof pageTitle !== 'undefined' && pageTitle ? pageTitle + ' — StochastiQdata' : 'StochastiQdata — Plateforme Datasets & Modèles Assurance & Banque' %></title>

  <!-- ── SEO ── -->
  <meta name="description" content="<%= typeof pageDescription !== 'undefined' && pageDescription ? pageDescription : 'Plateforme de modélisation et visualisation de données assurance et banque. Datasets qualifiés, modèles de référence, notebooks et benchmarks.' %>">
  <meta name="keywords" content="datasets assurance, modélisation données banque, visualisation données assurance, machine learning assurance, pricing IARD, fraude, risque crédit, provisionnement, GLM, XGBoost, Chain Ladder, tarification, sinistre, mortalité">
  <meta name="robots" content="<%= typeof noIndex !== 'undefined' && noIndex ? 'noindex, nofollow' : 'index, follow' %>">
  <meta name="author" content="StochastiQdata">
  <link rel="canonical" href="<%= siteUrl %><%- typeof canonicalPath !== 'undefined' && canonicalPath ? canonicalPath : currentPath %>">

  <!-- ── Open Graph ── -->
  <meta property="og:title" content="<%= typeof pageTitle !== 'undefined' && pageTitle ? pageTitle + ' — StochastiQdata' : 'StochastiQdata — Datasets Assurance & Banque' %>">
  <meta property="og:description" content="<%= typeof pageDescription !== 'undefined' && pageDescription ? pageDescription : 'Plateforme de référence pour les professionnels de l\'assurance et de la banque.' %>">
  <meta property="og:type" content="<%= typeof ogType !== 'undefined' && ogType ? ogType : 'website' %>">
  <meta property="og:url" content="<%= siteUrl %><%- currentPath %>">
  <meta property="og:image" content="<%= siteUrl %>/images/og-cover.png">
  <meta property="og:site_name" content="StochastiQdata">
  <meta property="og:locale" content="fr_FR">

  <!-- ── Twitter Card ── -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= typeof pageTitle !== 'undefined' && pageTitle ? pageTitle + ' — StochastiQdata' : 'StochastiQdata' %>">
  <meta name="twitter:description" content="<%= typeof pageDescription !== 'undefined' && pageDescription ? pageDescription : 'Plateforme de référence pour les professionnels de l\'assurance et de la banque.' %>">
  <meta name="twitter:image" content="<%= siteUrl %>/images/og-cover.png">

  <!-- ── Favicon ── -->
  <link rel="shortcut icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/images/logo.png">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="apple-touch-icon" href="/images/logo.png">

  <!-- ── CSS critique (préchargé) ── -->
  <link rel="preload" href="/css/output.css" as="style">
  <link rel="stylesheet" href="/css/output.css">

  <!-- ── Fonts ── -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  <!-- ── Chart.js (différé — non bloquant au rendu) ── -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" defer></script>

  <!-- ── JSON-LD ── -->
  <% if (typeof jsonLd !== 'undefined' && jsonLd) { %>
  <script type="application/ld+json"><%- JSON.stringify(jsonLd) %></script>
  <% } %>
</head>
<body class="bg-mesh min-h-screen transition-colors duration-300">
  <!-- Background decorations -->
  <div class="fixed inset-0 overflow-hidden pointer-events-none -z-10">
    <div class="absolute -top-40 -right-40 w-[500px] h-[500px] bg-gradient-to-br from-pink-500/20 to-purple-600/20 dark:from-pink-500/30 dark:to-purple-600/30 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-40 -left-40 w-[500px] h-[500px] bg-gradient-to-tr from-teal-400/20 to-cyan-500/20 dark:from-teal-400/30 dark:to-cyan-500/30 rounded-full blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-r from-indigo-500/10 to-purple-500/10 dark:from-indigo-500/20 dark:to-purple-500/20 rounded-full blur-3xl"></div>
  </div>

  <div class="relative flex min-h-screen overflow-x-hidden">
    <!-- Sidebar Desktop uniquement -->
    <%- include('partials/sidebar') %>

    <!-- Overlay pour mobile -->
    <div id="sidebarOverlay" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[80] lg:hidden hidden"></div>

    <!-- Main Content Area -->
    <div class="flex-1 min-w-0 lg:ml-72 p-3 sm:p-4 lg:p-6">
      <!-- Header -->
      <%- include('partials/header') %>

      <!-- Page Content -->
      <main class="mt-4 lg:mt-6">
        <%- body %>
      </main>
    </div>
  </div>

  <!-- Authentification supprimée - Sera réimplémentée -->

  <script src="/js/main.js"></script>

  <!-- ── Transitions de page fluides ── -->
  <div id="pt-overlay"></div>
  <script>
  (function () {
    var ov = document.getElementById('pt-overlay');
    document.addEventListener('DOMContentLoaded', function () {
      ov.classList.add('pt-out');
    });
    document.addEventListener('click', function (e) {
      var a = e.target.closest('a[href]');
      if (!a) return;
      var href = a.getAttribute('href');
      if (!href || href.startsWith('#') || href.startsWith('http') || href.startsWith('mailto') || a.target === '_blank') return;
      e.preventDefault();
      ov.classList.remove('pt-out');
      ov.classList.add('pt-in');
      setTimeout(function () { window.location.href = href; }, 180);
    });
  })();
  </script>
</body>
</html>
